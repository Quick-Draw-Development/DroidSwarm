{
  "name": "orchestrator",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/orchestrator/src",
  "projectType": "application",
  "targets": {
    "build": {
    "dependsOn": [
        "protocol:build",
        "protocol-alias:build"
      ],
      "executor": "@nx/esbuild:esbuild",
      "outputs": [
        "{options.outputPath}"
      ],
      "defaultConfiguration": "production",
      "options": {
        "platform": "node",
        "outputPath": "dist/apps/orchestrator",
        "format": [
          "cjs"
        ],
        "bundle": false,
        "main": "apps/orchestrator/src/main.ts",
        "tsConfig": "apps/orchestrator/tsconfig.app.json",
        "generatePackageJson": true,
        "assets": [
          {
            "glob": "**/*",
            "input": "dist/packages/protocol",
            "output": "packages/protocol"
          },
          {
            "glob": "**/*",
            "input": "dist/packages/protocol-alias",
            "output": "packages/protocol-alias"
          }
        ],
        "esbuildOptions": {
          "sourcemap": true,
          "outExtension": {
            ".js": ".js"
          }
        }
      },
      "configurations": {
        "development": {},
        "production": {
          "esbuildOptions": {
            "sourcemap": false,
            "outExtension": {
              ".js": ".js"
            }
          }
        }
      }
    },
    "prune-lockfile": {
      "dependsOn": [
        "build"
      ],
      "cache": true,
      "executor": "@nx/js:prune-lockfile",
      "outputs": [
        "{workspaceRoot}/dist/apps/orchestrator/package.json",
        "{workspaceRoot}/dist/apps/orchestrator/package-lock.json"
      ],
      "options": {
        "buildTarget": "build"
      }
    },
    "copy-workspace-modules": {
      "dependsOn": [
        "build"
      ],
      "cache": true,
      "outputs": [
        "{workspaceRoot}/dist/apps/orchestrator/workspace_modules"
      ],
      "executor": "@nx/js:copy-workspace-modules",
      "options": {
        "buildTarget": "build"
      }
    },
    "prune": {
      "dependsOn": [
        "prune-lockfile",
        "copy-workspace-modules"
      ],
      "executor": "nx:noop"
    },
    "serve": {
      "continuous": true,
      "executor": "@nx/js:node",
      "defaultConfiguration": "development",
      "dependsOn": [
        "build"
      ],
      "options": {
        "buildTarget": "orchestrator:build",
        "runBuildTargetDependencies": false
      },
      "configurations": {
        "development": {
          "buildTarget": "orchestrator:build:development"
        },
        "production": {
          "buildTarget": "orchestrator:build:production"
        }
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node --import tsx --test apps/orchestrator/src/**/*.spec.ts"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --noEmit -p apps/orchestrator/tsconfig.app.json"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --noEmit -p apps/orchestrator/tsconfig.app.json"
      }
    }
  },
  "tags": []
}
