{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "priority": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/api/channels/[taskId]/messages",
      "regex": "^/api/channels/([^/]+?)/messages(?:/)?$",
      "routeKeys": {
        "nxtPtaskId": "nxtPtaskId"
      },
      "namedRegex": "^/api/channels/(?<nxtPtaskId>[^/]+?)/messages(?:/)?$"
    },
    {
      "page": "/api/tasks/[taskId]/status",
      "regex": "^/api/tasks/([^/]+?)/status(?:/)?$",
      "routeKeys": {
        "nxtPtaskId": "nxtPtaskId"
      },
      "namedRegex": "^/api/tasks/(?<nxtPtaskId>[^/]+?)/status(?:/)?$"
    },
    {
      "page": "/channels/[taskId]",
      "regex": "^/channels/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPtaskId": "nxtPtaskId"
      },
      "namedRegex": "^/channels/(?<nxtPtaskId>[^/]+?)(?:/)?$"
    },
    {
      "page": "/projects/[projectId]",
      "regex": "^/projects/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPprojectId": "nxtPprojectId"
      },
      "namedRegex": "^/projects/(?<nxtPprojectId>[^/]+?)(?:/)?$"
    },
    {
      "page": "/projects/[projectId]/runs/[runId]",
      "regex": "^/projects/([^/]+?)/runs/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPprojectId": "nxtPprojectId",
        "nxtPrunId": "nxtPrunId"
      },
      "namedRegex": "^/projects/(?<nxtPprojectId>[^/]+?)/runs/(?<nxtPrunId>[^/]+?)(?:/)?$"
    },
    {
      "page": "/projects/[projectId]/tasks/[taskId]",
      "regex": "^/projects/([^/]+?)/tasks/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPprojectId": "nxtPprojectId",
        "nxtPtaskId": "nxtPtaskId"
      },
      "namedRegex": "^/projects/(?<nxtPprojectId>[^/]+?)/tasks/(?<nxtPtaskId>[^/]+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
