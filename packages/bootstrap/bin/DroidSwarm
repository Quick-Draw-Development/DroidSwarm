#!/usr/bin/env bash

set -euo pipefail

resolve_script_path() {
  local source_path="${BASH_SOURCE[0]}"
  while [[ -L "$source_path" ]]; do
    local source_dir
    source_dir="$(cd -P "$(dirname "$source_path")" && pwd)"
    source_path="$(readlink "$source_path")"
    [[ "$source_path" != /* ]] && source_path="$source_dir/$source_path"
  done
  printf '%s\n' "$(cd -P "$(dirname "$source_path")" && pwd)/$(basename "$source_path")"
}

find_version_file() {
  local candidate
  for candidate in \
    "$ROOT_DIR/VERSION" \
    "$ROOT_DIR/../VERSION" \
    "$ROOT_DIR/../../VERSION" \
    "$ROOT_DIR/../../../VERSION"; do
    if [[ -f "$candidate" ]]; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done

  return 1
}


read_version_value() {
  local version_file
  if version_file="$(find_version_file)" && [[ -f "$version_file" ]]; then
    local version
    IFS= read -r version <"$version_file"
    printf '%s\n' "${version:-0.0.0}"
    return 0
  fi

  printf '0.0.0\n'
  return 1
}


SCRIPT_PATH="$(resolve_script_path)"
SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
ROOT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

# shellcheck source=../lib/droidswarm/common.sh
source "$ROOT_DIR/lib/droidswarm/common.sh"

DROIDSWARM_VERSION="$(read_version_value)"
export DROIDSWARM_VERSION

COMMAND="${1:-help}"
if [[ $# -gt 0 ]]; then
  shift
fi

print_help() {
  cat <<'EOF'
Usage:
  DroidSwarm <command> [options]

Commands:
  setup       Initialize a project for DroidSwarm
  swarm       Start and register a managed DroidSwarm instance
  orchestrator Inspect orchestrator state and send task-channel messages
  list        List tracked swarms running on this machine
  status      Show detailed status for one managed DroidSwarm instance
  cleanup     Remove stopped/failed swarm records and logs
  repair      Repair the local DroidSwarm install and optionally reinstall cleanly
  shutdown    Shut down one swarm or all swarms
  version     Show the installed DroidSwarm version
  update      Refresh the installed runtime and restart swarms
  help        Show this help

Examples:
  DroidSwarm setup --project-root "$PWD" --project-mode greenfield
  DroidSwarm swarm --project-root "$PWD" --env OPENAI_API_KEY=example --config mode=dev
  DroidSwarm orchestrator status
  DroidSwarm orchestrator status --task-id <task-id>
  DroidSwarm orchestrator message --task-id <task-id> --content "Need an update"
  DroidSwarm list
  DroidSwarm status --swarm-id <id>
  DroidSwarm cleanup
  DroidSwarm cleanup --all --shutdown-running
  DroidSwarm repair
  DroidSwarm repair --clean
  DroidSwarm shutdown --swarm-id <id>
  DroidSwarm shutdown --all
EOF
}

print_setup_help() {
  cat <<'EOF'
Usage:
  DroidSwarm setup [options]

Options:
  --project-root PATH
  --project-mode MODE        Required: greenfield | existing
  --project-name NAME
  --project-id ID
  --main-branch NAME
  --production-branch NAME
  --dashboard-port PORT
  --ws-port PORT
  --db-path PATH
  --force
  --help
EOF
}

print_swarm_help() {
  cat <<'EOF'
Usage:
  DroidSwarm swarm [options]

Options:
  --swarm-id ID
  --project-root PATH
  --project-name NAME
  --project-id ID
  --dashboard-port PORT
  --ws-port PORT
  --agent-count N
  --main-branch NAME
  --production-branch NAME
  --repo-url URL
  --blink-port PORT
  --mux-port PORT
  --llama-port PORT
  --llama-model PATH
  --env KEY=VALUE           Repeatable
  --config KEY=VALUE        Repeatable
  --debug
  --no-debug
  --foreground
  --dry-run
  --help
EOF
}

print_update_help() {
  cat <<'EOF'
Usage:
  DroidSwarm update [options]

Options:
  --repo-url URL
  --ref REF
  --install-root DIR
  --bin-dir DIR
  --force
  --help
EOF
}

print_repair_help() {
  cat <<'EOF'
Usage:
  DroidSwarm repair [options]

Options:
  --repo-url URL
  --ref REF
  --install-root DIR
  --bin-dir DIR
  --clean
  --no-restart
  --help
EOF
}

print_status_help() {
  cat <<'EOF'
Usage:
  DroidSwarm status [--swarm-id <id>]

Options:
  --swarm-id ID
  --help
EOF
}

print_cleanup_help() {
  cat <<'EOF'
Usage:
  DroidSwarm cleanup [options]

Options:
  --swarm-id ID
  --all
  --shutdown-running
  --help
EOF
}

print_version() {
  printf 'DroidSwarm %s\n' "${DROIDSWARM_VERSION:-0.0.0}"
}

print_orchestrator_help() {
  cat <<'EOF'
Usage:
  DroidSwarm orchestrator status [options]
  DroidSwarm orchestrator message [options]

Status options:
  --swarm-id ID
  --task-id ID
  --limit N

Message options:
  --swarm-id ID
  --task-id ID              Required
  --content TEXT            Required
  --username NAME           Default: operator_cli

Examples:
  DroidSwarm orchestrator status
  DroidSwarm orchestrator status --task-id <task-id>
  DroidSwarm orchestrator message --task-id <task-id> --content "What is blocked?"
EOF
}

resolve_runtime_value() {
  local env_value="$1"
  shift

  if [[ -n "$env_value" && -f "$env_value" ]]; then
    printf '%s\n' "$env_value"
    return 0
  fi

  local candidate
  for candidate in "$@"; do
    if [[ -n "$candidate" && -f "$candidate" ]]; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done

  return 1
}

resolve_runtime_dir_value() {
  local env_value="$1"
  shift

  if [[ -n "$env_value" && -d "$env_value" ]]; then
    printf '%s\n' "$env_value"
    return 0
  fi

  local candidate
  for candidate in "$@"; do
    if [[ -n "$candidate" && -d "$candidate" ]]; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done

  return 1
}

resolve_swarm_id() {
  local swarm_id="${1:-}"
  if [[ -n "$swarm_id" ]]; then
    if ! swarm_exists "$swarm_id"; then
      err "Unknown swarm: $swarm_id"
      return 1
    fi
    printf '%s\n' "$swarm_id"
    return 0
  fi

  local detected_ids=()
  local active_id
  for active_id in $(active_swarm_ids); do
    detected_ids+=("$active_id")
  done

  if [[ "${#detected_ids[@]}" -eq 0 ]]; then
    err "No DroidSwarm instances found."
    return 1
  fi

  if [[ "${#detected_ids[@]}" -gt 1 ]]; then
    err "Multiple swarms found. Re-run with --swarm-id."
    cmd_list --all
    return 1
  fi

  printf '%s\n' "${detected_ids[0]}"
}

sql_escape() {
  local value="${1:-}"
  printf "%s" "${value//\'/\'\'}"
}

resolve_repair_script_path() {
  local candidate
  for candidate in \
    "$ROOT_DIR/scripts/repair-droidswarm.sh" \
    "$ROOT_DIR/bin/repair-droidswarm"; do
    if [[ -x "$candidate" ]]; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done

  return 1
}

service_runtime_config_is_valid() {
  local config_file="${1:-$DROIDSWARM_SERVICE_CONFIG}"

  [[ -f "$config_file" ]] || return 1
  /bin/bash -n "$config_file" >/dev/null 2>&1 || return 1

  env -i DROIDSWARM_SERVICE_CONFIG="$config_file" /bin/bash -lc '
    set -euo pipefail
    source "$DROIDSWARM_SERVICE_CONFIG"
    [[ -n "${DROIDSWARM_BLINK_SERVER_BIN:-}" ]]
    [[ -n "${DROIDSWARM_MUX_BIN:-}" ]]
    [[ -n "${DROIDSWARM_LLAMA_SERVER_BIN:-}" ]]
    [[ -n "${DROIDSWARM_LLAMA_MODEL:-}" ]]
    [[ -x "${DROIDSWARM_BLINK_SERVER_BIN:-}" ]]
    [[ -x "${DROIDSWARM_MUX_BIN:-}" ]]
    [[ -x "${DROIDSWARM_LLAMA_SERVER_BIN:-}" ]]
    [[ -f "${DROIDSWARM_LLAMA_MODEL:-}" ]]
  ' >/dev/null 2>&1
}

ensure_service_runtime_ready() {
  local repair_script=""
  local install_root="${DROIDSWARM_INSTALL_ROOT:-$DROIDSWARM_HOME/install}"
  local bin_dir="${DROIDSWARM_BIN_DIR:-$HOME/.local/bin}"

  if service_runtime_config_is_valid "$DROIDSWARM_SERVICE_CONFIG"; then
    return 0
  fi

  warn "Local DroidSwarm service runtime is missing or invalid. Attempting automatic repair."
  repair_script="$(resolve_repair_script_path)" || {
    err "Unable to locate repair script for automatic service recovery."
    return 1
  }

  DROIDSWARM_INSTALL_ROOT="$install_root" \
    DROIDSWARM_BIN_DIR="$bin_dir" \
    DROIDSWARM_HOME="$DROIDSWARM_HOME" \
    /bin/bash "$repair_script" --no-restart

  if ! service_runtime_config_is_valid "$DROIDSWARM_SERVICE_CONFIG"; then
    err "Automatic service repair completed, but the runtime configuration is still invalid."
    return 1
  fi
}

service_listener_is_adoptable() {
  local service_name="$1"
  local port="$2"
  local expected_bin="$3"
  shift 3

  local listener_pid="" command_line="" expected_name="" token=""
  listener_pid="$(listener_pid_for_port "$port" || true)"
  [[ -n "$listener_pid" ]] || return 1

  command_line="$(command_line_for_pid "$listener_pid" || true)"
  [[ -n "$command_line" ]] || return 1

  expected_name="$(basename "$expected_bin")"
  command_line="$(printf '%s' "$command_line" | tr '[:upper:]' '[:lower:]')"
  expected_name="$(printf '%s' "$expected_name" | tr '[:upper:]' '[:lower:]')"

  if [[ -n "$expected_name" && "$command_line" == *"$expected_name"* ]]; then
    return 0
  fi

  for token in "$@"; do
    token="$(printf '%s' "$token" | tr '[:upper:]' '[:lower:]')"
    if [[ -n "$token" && "$command_line" == *"$token"* ]]; then
      return 0
    fi
  done

  local swarm_id candidate_pid candidate_port
  for swarm_id in $(active_swarm_ids); do
    if ! load_swarm_env "$swarm_id"; then
      continue
    fi

    case "$service_name" in
      blink-server)
        candidate_port="${DROIDSWARM_BLINK_SERVER_PORT:-}"
        ;;
      mux)
        candidate_port="${DROIDSWARM_MUX_PORT:-}"
        ;;
      llama.cpp)
        candidate_port="${DROIDSWARM_LLAMA_PORT:-}"
        ;;
      *)
        candidate_port=""
        ;;
    esac

    [[ "$candidate_port" == "$port" ]] || continue
    candidate_pid=""
    if [[ -f "$(service_pid_file "$service_name" "$(swarm_dir "$swarm_id")")" ]]; then
      candidate_pid="$(<"$(service_pid_file "$service_name" "$(swarm_dir "$swarm_id")")")"
    fi
    if [[ -n "$candidate_pid" && "$candidate_pid" == "$listener_pid" ]]; then
      return 0
    fi
  done

  return 1
}

resolve_service_binding() {
  local service_name="$1"
  local requested_port="$2"
  local explicit_flag="$3"
  local default_port="$4"
  local expected_bin="$5"
  shift 5

  local listener_pid=""
  if port_is_free "$requested_port"; then
    printf 'use|%s|\n' "$requested_port"
    return 0
  fi

  listener_pid="$(listener_pid_for_port "$requested_port" || true)"
  if service_listener_is_adoptable "$service_name" "$requested_port" "$expected_bin" "$@"; then
    printf 'adopt|%s|%s\n' "$requested_port" "$listener_pid"
    return 0
  fi

  if [[ "$explicit_flag" == "1" ]]; then
    err "$service_name port is already in use: $requested_port"
    return 1
  fi

  printf 'use|%s|\n' "$(next_available_port "$default_port")"
}


write_project_metadata() {
  local project_root="$1"
  local project_name="$2"
  local project_id="$3"
  local project_mode="$4"
  local main_branch="$5"
  local production_branch="$6"
  local dashboard_port="$7"
  local ws_port="$8"
  local db_path="$9"

  local meta_dir meta_file
  meta_dir="$(project_meta_dir "$project_root")"
  meta_file="$(project_meta_file "$project_root")"

  mkdir -p "$meta_dir"

  cat >"$meta_file" <<EOF
{
  "project_name": "$(json_escape "$project_name")",
  "project_id": "$(json_escape "$project_id")",
  "project_mode": "$(json_escape "$project_mode")",
  "main_branch": "$(json_escape "$main_branch")",
  "production_branch": "$(json_escape "$production_branch")",
  "db_path": "$(json_escape "$db_path")",
  "dashboard_port": $dashboard_port,
  "ws_port": $ws_port
}
EOF
}

write_project_setup_state() {
  local project_root="$1"
  local project_name="$2"
  local project_id="$3"
  local project_mode="$4"
  local main_branch="$5"
  local production_branch="$6"
  local dashboard_port="$7"
  local ws_port="$8"
  local db_path="$9"
  local version="${10:-${DROIDSWARM_VERSION:-}}"
  local spec_dir="${11:-}"

  cat >"$(project_setup_file "$project_root")" <<EOF
DROIDSWARM_PROJECT_ROOT=$(printf '%q' "$project_root")
DROIDSWARM_PROJECT_NAME=$(printf '%q' "$project_name")
DROIDSWARM_PROJECT_ID=$(printf '%q' "$project_id")
DROIDSWARM_PROJECT_MODE=$(printf '%q' "$project_mode")
DROIDSWARM_MAIN_BRANCH=$(printf '%q' "$main_branch")
DROIDSWARM_PRODUCTION_BRANCH=$(printf '%q' "$production_branch")
DROIDSWARM_DASHBOARD_PORT=$(printf '%q' "$dashboard_port")
DROIDSWARM_WS_PORT=$(printf '%q' "$ws_port")
DROIDSWARM_DB_PATH=$(printf '%q' "$db_path")
DROIDSWARM_VERSION=$(printf '%q' "$version")
DROIDSWARM_SPECS_DIR=$(printf '%q' "$spec_dir")
DROIDSWARM_SETUP_COMPLETED_AT=$(printf '%q' "$(now_utc)")
EOF
}

load_project_setup() {
  local project_root="$1"
  local setup_file
  setup_file="$(project_setup_file "$project_root")"
  if [[ ! -f "$setup_file" ]]; then
    return 1
  fi

  # shellcheck disable=SC1090
  source "$setup_file"
}

cmd_setup() {
  ensure_runtime_dirs

  local project_root project_name project_id project_mode main_branch production_branch
  local dashboard_port ws_port db_path force specs_dir
  project_root="$(pwd)"
  project_name=""
  project_id=""
  project_mode=""
  main_branch=""
  production_branch="production"
  dashboard_port=""
  ws_port=""
  db_path=""
  force="0"
  specs_dir="$ROOT_DIR/specs"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --project-root)
        shift
        require_value "--project-root" "${1:-}"
        project_root="$1"
        ;;
      --project-mode)
        shift
        require_value "--project-mode" "${1:-}"
        project_mode="$1"
        ;;
      --project-name)
        shift
        require_value "--project-name" "${1:-}"
        project_name="$1"
        ;;
      --project-id)
        shift
        require_value "--project-id" "${1:-}"
        project_id="$1"
        ;;
      --main-branch)
        shift
        require_value "--main-branch" "${1:-}"
        main_branch="$1"
        ;;
      --production-branch)
        shift
        require_value "--production-branch" "${1:-}"
        production_branch="$1"
        ;;
      --dashboard-port)
        shift
        require_value "--dashboard-port" "${1:-}"
        dashboard_port="$1"
        ;;
      --ws-port)
        shift
        require_value "--ws-port" "${1:-}"
        ws_port="$1"
        ;;
      --db-path)
        shift
        require_value "--db-path" "${1:-}"
        db_path="$1"
        ;;
      --force)
        force="1"
        ;;
      --help|-h)
        print_setup_help
        return 0
        ;;
      *)
        err "Unknown setup option: $1"
        print_setup_help
        return 1
        ;;
    esac
    shift
  done

  mkdir -p "$project_root"
  project_root="$(cd "$project_root" && pwd)"

  if [[ "$force" != "1" ]] && project_is_setup "$project_root"; then
    err "Project is already set up: $project_root"
    err "Use --force to regenerate setup metadata."
    return 1
  fi

  if [[ -z "$project_mode" ]]; then
    err "Missing required option: --project-mode"
    err "Allowed values: greenfield | existing"
    return 1
  fi

  case "$project_mode" in
    greenfield|existing)
      ;;
    *)
      err "Invalid --project-mode: $project_mode"
      err "Allowed values: greenfield | existing"
      return 1
      ;;
  esac

  if [[ -z "$project_name" ]]; then
    project_name="$(read_package_name "$project_root" || true)"
  fi

  if [[ -z "$project_name" ]]; then
    project_name="$(git_repo_name "$project_root" || true)"
  fi

  if [[ -z "$project_name" ]]; then
    project_name="$(basename "$project_root")"
  fi

  if [[ -z "$project_id" ]]; then
    project_id="$(slugify "$project_name")"
  fi

  if [[ -z "$main_branch" ]]; then
    main_branch="$(detect_main_branch "$project_root")"
  fi

  if [[ -z "$dashboard_port" ]]; then
    dashboard_port="$(next_available_port 3000)"
  fi

  if [[ -z "$ws_port" ]]; then
    ws_port="$(next_available_port 8765)"
    if [[ "$ws_port" == "$dashboard_port" ]]; then
      ws_port=$((ws_port + 1))
    fi
  fi

  if [[ -z "$db_path" ]]; then
    db_path="$(project_db_file "$project_root")"
  fi

  mkdir -p "$(dirname "$db_path")"
  touch "$db_path"
  mkdir -p "$(project_meta_dir "$project_root")"

  write_project_metadata \
    "$project_root" \
    "$project_name" \
    "$project_id" \
    "$project_mode" \
    "$main_branch" \
    "$production_branch" \
    "$dashboard_port" \
    "$ws_port" \
    "$db_path"

  write_project_setup_state \
    "$project_root" \
    "$project_name" \
    "$project_id" \
    "$project_mode" \
    "$main_branch" \
    "$production_branch" \
    "$dashboard_port" \
    "$ws_port" \
    "$db_path" \
    "$DROIDSWARM_VERSION"
    "$specs_dir"

  ensure_gitignore_entry "$project_root" ".droidswarm/*"
  ensure_gitignore_entry "$project_root" "!.droidswarm/.gitkeep"
  touch "$(project_meta_dir "$project_root")/.gitkeep"

  info "Initialized DroidSwarm project setup."
  info "Project root: $project_root"
  info "Project: $project_name ($project_id)"
  info "Project mode: $project_mode"
  info "Main branch: $main_branch"
  info "Production branch: $production_branch"
  info "Metadata: $(project_meta_file "$project_root")"
  info "Database: $db_path"
}

cmd_swarm() {
  ensure_runtime_dirs

  local project_root project_name project_id project_mode swarm_id dashboard_port ws_port db_path
  local agent_count main_branch production_branch repo_url foreground dry_run
  local debug_enabled debug_explicit
  local dashboard_port_explicit ws_port_explicit
  local blink_port_explicit mux_port_explicit llama_port_explicit
  local node_bin operator_token socket_server_entry orchestrator_entry dashboard_server_entry
  local blink_bridge_entry worker_host_entry
  local dashboard_static_dir dashboard_public_dir dashboard_workdir
  local specs_dir
  local blink_port mux_port llama_port llama_model
  project_root="$(pwd)"
  project_name=""
  project_id=""
  project_mode=""
  swarm_id=""
  dashboard_port=""
  ws_port=""
  db_path=""
  agent_count="0"
  main_branch="main"
  production_branch="production"
  repo_url=""
  foreground="0"
  dry_run="0"
  debug_enabled="${DROIDSWARM_DEBUG:-}"
  debug_explicit="0"
  dashboard_port_explicit="0"
  ws_port_explicit="0"
  blink_port_explicit="0"
  mux_port_explicit="0"
  llama_port_explicit="0"
  node_bin="${DROIDSWARM_NODE_BIN:-$(command -v node || true)}"
  operator_token="${DROIDSWARM_OPERATOR_TOKEN:-}"
  socket_server_entry=""
  orchestrator_entry=""
  dashboard_server_entry=""
  dashboard_static_dir=""
  dashboard_public_dir=""
  dashboard_workdir=""
  blink_bridge_entry=""
  worker_host_entry=""
  blink_port=""
  mux_port=""
  llama_port=""
  llama_model="${DROIDSWARM_LLAMA_MODEL:-}"

  local -a env_pairs=()
  local -a config_pairs=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --swarm-id)
        shift
        require_value "--swarm-id" "${1:-}"
        swarm_id="$1"
        ;;
      --project-root)
        shift
        require_value "--project-root" "${1:-}"
        project_root="$1"
        ;;
      --project-name)
        shift
        require_value "--project-name" "${1:-}"
        project_name="$1"
        ;;
      --project-id)
        shift
        require_value "--project-id" "${1:-}"
        project_id="$1"
        ;;
      --dashboard-port)
        shift
        require_value "--dashboard-port" "${1:-}"
        dashboard_port="$1"
        dashboard_port_explicit="1"
        ;;
      --ws-port)
        shift
        require_value "--ws-port" "${1:-}"
        ws_port="$1"
        ws_port_explicit="1"
        ;;
      --agent-count)
        shift
        require_value "--agent-count" "${1:-}"
        agent_count="$1"
        ;;
      --main-branch)
        shift
        require_value "--main-branch" "${1:-}"
        main_branch="$1"
        ;;
      --production-branch)
        shift
        require_value "--production-branch" "${1:-}"
        production_branch="$1"
        ;;
      --repo-url)
        shift
        require_value "--repo-url" "${1:-}"
        repo_url="$1"
        ;;
      --blink-port)
        shift
        require_value "--blink-port" "${1:-}"
        blink_port="$1"
        blink_port_explicit="1"
        ;;
      --mux-port)
        shift
        require_value "--mux-port" "${1:-}"
        mux_port="$1"
        mux_port_explicit="1"
        ;;
      --llama-port)
        shift
        require_value "--llama-port" "${1:-}"
        llama_port="$1"
        llama_port_explicit="1"
        ;;
      --llama-model)
        shift
        require_value "--llama-model" "${1:-}"
        llama_model="$1"
        ;;
      --env)
        shift
        require_value "--env" "${1:-}"
        env_pairs+=("$1")
        ;;
      --config)
        shift
        require_value "--config" "${1:-}"
        config_pairs+=("$1")
        ;;
      --debug)
        debug_enabled="1"
        debug_explicit="1"
        ;;
      --no-debug)
        debug_enabled="0"
        debug_explicit="1"
        ;;
      --foreground)
        foreground="1"
        ;;
      --dry-run)
        dry_run="1"
        ;;
      --help|-h)
        print_swarm_help
        return 0
        ;;
      *)
        err "Unknown swarm option: $1"
        print_swarm_help
        return 1
        ;;
    esac
    shift
  done

  mkdir -p "$project_root"
  project_root="$(cd "$project_root" && pwd)"

  if ! project_is_setup "$project_root"; then
    err "Project is not set up: $project_root"
    err "Run: DroidSwarm setup --project-root \"$project_root\" --project-mode <greenfield|existing>"
    return 1
  fi

  load_project_setup "$project_root"

  if [[ -z "$project_name" ]]; then
    project_name="${DROIDSWARM_PROJECT_NAME:-}"
  fi

  if [[ -z "$project_id" ]]; then
    project_id="${DROIDSWARM_PROJECT_ID:-}"
  fi

  project_mode="${DROIDSWARM_PROJECT_MODE:-}"

  if [[ -z "$main_branch" ]]; then
    main_branch="${DROIDSWARM_MAIN_BRANCH:-main}"
  fi

  if [[ -z "$production_branch" ]]; then
    production_branch="${DROIDSWARM_PRODUCTION_BRANCH:-production}"
  fi

  if [[ "$debug_explicit" != "1" && -z "$debug_enabled" ]]; then
    debug_enabled="${DROIDSWARM_DEBUG:-0}"
  fi

  db_path="${DROIDSWARM_DB_PATH:-}"
  if [[ -z "$db_path" ]]; then
    db_path="$(project_db_file "$project_root")"
  fi

  if [[ -z "$swarm_id" ]]; then
    swarm_id="${project_id}-$(date +%s)"
  fi

  if swarm_exists "$swarm_id"; then
    err "Swarm already exists: $swarm_id"
    return 1
  fi

  replace_project_swarms "$project_root" "$project_id" "$swarm_id"

  if [[ -z "$dashboard_port" ]]; then
    dashboard_port="${DROIDSWARM_DASHBOARD_PORT:-}"
  fi

  if [[ -z "$dashboard_port" ]]; then
    dashboard_port="$(next_available_port 3000)"
  elif ! port_is_free "$dashboard_port"; then
    if [[ "$dashboard_port_explicit" == "1" ]]; then
      err "Dashboard port is already in use: $dashboard_port"
      return 1
    fi
    dashboard_port="$(next_available_port 3000)"
  fi

  if [[ -z "$ws_port" ]]; then
    ws_port="${DROIDSWARM_WS_PORT:-}"
  fi

  if [[ -z "$ws_port" ]]; then
    ws_port="$(next_available_port 8765)"
  elif [[ "$ws_port" == "$dashboard_port" ]] || ! port_is_free "$ws_port"; then
    if [[ "$ws_port_explicit" == "1" ]]; then
      if [[ "$ws_port" == "$dashboard_port" ]]; then
        err "WebSocket port must be different from dashboard port: $ws_port"
      else
        err "WebSocket port is already in use: $ws_port"
      fi
      return 1
    fi
    ws_port="$(next_available_port 8765)"
  fi

  while [[ "$ws_port" == "$dashboard_port" ]] || ! port_is_free "$ws_port"; do
    ws_port=$((ws_port + 1))
  done

  local state_dir log_file
  state_dir="$(swarm_dir "$swarm_id")"
  log_file="$(swarm_log_file "$swarm_id")"
  local workspace_root install_runtime_root install_models_root
  local blink_adopt mux_adopt llama_adopt
  local blink_adopt_pid mux_adopt_pid llama_adopt_pid
  local blink_binding mux_binding llama_binding
  workspace_root="$(cd "$ROOT_DIR/../.." 2>/dev/null && pwd || true)"
  install_runtime_root="$ROOT_DIR/runtime"
  install_models_root="${DROIDSWARM_MODELS_DIR:-$DROIDSWARM_HOME/models}"
  specs_dir="$ROOT_DIR/specs"
  blink_adopt="0"
  mux_adopt="0"
  llama_adopt="0"
  blink_adopt_pid=""
  mux_adopt_pid=""
  llama_adopt_pid=""

  if [[ -z "$node_bin" || ! -x "$node_bin" ]]; then
    err "Node.js is required to start a swarm."
    return 1
  fi

  socket_server_entry="$(resolve_runtime_value "${DROIDSWARM_SOCKET_SERVER_ENTRY:-}" \
    "$install_runtime_root/socket-server/main.js" \
    "$workspace_root/dist/apps/socket-server/main.js" || true)"
  orchestrator_entry="$(resolve_runtime_value "${DROIDSWARM_ORCHESTRATOR_ENTRY:-}" \
    "$install_runtime_root/orchestrator/main.js" \
    "$workspace_root/dist/apps/orchestrator/main.js" || true)"
  dashboard_server_entry="$(resolve_runtime_value "${DROIDSWARM_DASHBOARD_SERVER_ENTRY:-}" \
    "$install_runtime_root/dashboard/server.js" \
    "$install_runtime_root/dashboard/apps/dashboard/server.js" \
    "$workspace_root/dist/apps/dashboard/.next/standalone/server.js" \
    "$workspace_root/dist/apps/dashboard/.next/standalone/apps/dashboard/server.js" || true)"
  dashboard_static_dir="$(resolve_runtime_dir_value "${DROIDSWARM_DASHBOARD_STATIC_DIR:-}" \
    "$install_runtime_root/dashboard/dist/apps/dashboard/.next/static" \
    "$install_runtime_root/dashboard/.next/static" \
    "$install_runtime_root/dashboard/apps/dashboard/.next/static" \
    "$workspace_root/dist/apps/dashboard/.next/static" || true)"
  dashboard_public_dir="$(resolve_runtime_dir_value "${DROIDSWARM_DASHBOARD_PUBLIC_DIR:-}" \
    "$install_runtime_root/dashboard/public" \
    "$install_runtime_root/dashboard/apps/dashboard/public" \
    "$workspace_root/apps/dashboard/public" || true)"
  blink_bridge_entry="$(resolve_runtime_value "${DROIDSWARM_BLINK_BRIDGE_ENTRY:-}" \
    "${DROIDSWARM_DEFAULT_BLINK_BRIDGE_ENTRY:-$install_runtime_root/blink-bridge/main.js}" \
    "$install_runtime_root/blink-bridge/main.js" \
    "$workspace_root/dist/apps/blink-bridge/main.js" || true)"
  worker_host_entry="$(resolve_runtime_value "${DROIDSWARM_WORKER_HOST_ENTRY:-}" \
    "${DROIDSWARM_DEFAULT_WORKER_HOST_ENTRY:-$install_runtime_root/worker-host/main.js}" \
    "$install_runtime_root/worker-host/main.js" \
    "$install_runtime_root/worker-host/main.cjs" \
    "$workspace_root/dist/apps/worker-host/main.js" \
    "$workspace_root/dist/apps/worker-host/main.cjs" || true)"

  if [[ -z "$socket_server_entry" ]]; then
    err "Missing socket-server build artifact."
    err "Expected dist/apps/socket-server/main.js or installed runtime copy."
    err "Run: nx build socket-server"
    return 1
  fi

  if [[ -z "$orchestrator_entry" ]]; then
    err "Missing orchestrator build artifact."
    err "Expected dist/apps/orchestrator/main.js or installed runtime copy."
    err "Run: nx build orchestrator"
    return 1
  fi

  if [[ -z "$dashboard_server_entry" ]]; then
    err "Missing dashboard standalone server artifact."
    err "Expected dist/apps/dashboard/.next/standalone/.../server.js or installed runtime copy."
    err "Run: nx build dashboard"
    return 1
  fi

  dashboard_workdir="$(cd "$(dirname "$dashboard_server_entry")" && pwd)"

  if [[ -z "$operator_token" ]]; then
    operator_token="$(uuid)"
  fi

  if ! ensure_service_runtime_ready; then
    return 1
  fi

  if [[ -f "$DROIDSWARM_SERVICE_CONFIG" ]]; then
    # shellcheck disable=SC1090
    source "$DROIDSWARM_SERVICE_CONFIG"
  fi

  if [[ -z "$blink_port" ]]; then
    blink_port="${DROIDSWARM_BLINK_SERVER_PORT:-8950}"
  fi
  blink_binding="$(resolve_service_binding "blink-server" "$blink_port" "$blink_port_explicit" 8950 "${DROIDSWARM_BLINK_SERVER_BIN:-}" "blink-server" "blink")" || return 1
  IFS='|' read -r blink_binding_action blink_port blink_adopt_pid <<<"$blink_binding"
  [[ "$blink_binding_action" == "adopt" ]] && blink_adopt="1"

  if [[ -z "$mux_port" ]]; then
    mux_port="${DROIDSWARM_MUX_PORT:-8960}"
  fi
  mux_binding="$(resolve_service_binding "mux" "$mux_port" "$mux_port_explicit" 8960 "${DROIDSWARM_MUX_BIN:-}" " mux " "/mux" "mux")" || return 1
  IFS='|' read -r mux_binding_action mux_port mux_adopt_pid <<<"$mux_binding"
  [[ "$mux_binding_action" == "adopt" ]] && mux_adopt="1"

  if [[ -z "$llama_port" ]]; then
    llama_port="${DROIDSWARM_LLAMA_PORT:-11434}"
  fi
  llama_binding="$(resolve_service_binding "llama.cpp" "$llama_port" "$llama_port_explicit" 11434 "${DROIDSWARM_LLAMA_SERVER_BIN:-}" "llama-server" "llama.cpp" "llama")" || return 1
  IFS='|' read -r llama_binding_action llama_port llama_adopt_pid <<<"$llama_binding"
  [[ "$llama_binding_action" == "adopt" ]] && llama_adopt="1"

  if [[ -z "$llama_model" ]]; then
    llama_model="${DROIDSWARM_LLAMA_MODEL:-${DROIDSWARM_DEFAULT_LLAMA_MODEL:-$install_models_root/default.gguf}}"
  fi

  info "Swarm ID: $swarm_id"
  info "Project: $project_name ($project_id)"
  info "Project root: $project_root"
  info "Dashboard port: $dashboard_port"
  info "WebSocket port: $ws_port"
  info "Debug logging: $( [[ "$debug_enabled" == "1" ]] && printf 'on' || printf 'off' )"

  if [[ "$dry_run" == "1" ]]; then
    return 0
  fi

  mkdir -p "$state_dir"
  printf 'starting\n' >"$(swarm_status_file "$swarm_id")"

  cat >"$(swarm_env_file "$swarm_id")" <<EOF
DROIDSWARM_SWARM_ID=$(printf '%q' "$swarm_id")
DROIDSWARM_PROJECT_ROOT=$(printf '%q' "$project_root")
DROIDSWARM_PROJECT_NAME=$(printf '%q' "$project_name")
DROIDSWARM_PROJECT_ID=$(printf '%q' "$project_id")
DROIDSWARM_PROJECT_MODE=$(printf '%q' "$project_mode")
DROIDSWARM_DASHBOARD_PORT=$(printf '%q' "$dashboard_port")
DROIDSWARM_WS_PORT=$(printf '%q' "$ws_port")
DROIDSWARM_DB_PATH=$(printf '%q' "$db_path")
DROIDSWARM_DEBUG=$(printf '%q' "$debug_enabled")
DROIDSWARM_AGENT_COUNT=$(printf '%q' "$agent_count")
DROIDSWARM_MAIN_BRANCH=$(printf '%q' "$main_branch")
DROIDSWARM_PRODUCTION_BRANCH=$(printf '%q' "$production_branch")
DROIDSWARM_REPO_URL=$(printf '%q' "$repo_url")
DROIDSWARM_CREATED_AT=$(printf '%q' "$(now_utc)")
DROIDSWARM_CREATED_EPOCH=$(printf '%q' "$(date +%s)")
DROIDSWARM_NODE_BIN=$(printf '%q' "$node_bin")
DROIDSWARM_OPERATOR_TOKEN=$(printf '%q' "$operator_token")
DROIDSWARM_SOCKET_SERVER_ENTRY=$(printf '%q' "$socket_server_entry")
DROIDSWARM_ORCHESTRATOR_ENTRY=$(printf '%q' "$orchestrator_entry")
DROIDSWARM_DASHBOARD_SERVER_ENTRY=$(printf '%q' "$dashboard_server_entry")
DROIDSWARM_DASHBOARD_STATIC_DIR=$(printf '%q' "$dashboard_static_dir")
DROIDSWARM_DASHBOARD_PUBLIC_DIR=$(printf '%q' "$dashboard_public_dir")
DROIDSWARM_DASHBOARD_WORKDIR=$(printf '%q' "$dashboard_workdir")
DROIDSWARM_BLINK_BRIDGE_ENTRY=$(printf '%q' "$blink_bridge_entry")
DROIDSWARM_WORKER_HOST_ENTRY=$(printf '%q' "$worker_host_entry")
DROIDSWARM_VERSION=$(printf '%q' "$DROIDSWARM_VERSION")
DROIDSWARM_SPECS_DIR=$(printf '%q' "$specs_dir")
DROIDSWARM_BLINK_SERVER_PORT=$(printf '%q' "$blink_port")
DROIDSWARM_MUX_PORT=$(printf '%q' "$mux_port")
DROIDSWARM_LLAMA_PORT=$(printf '%q' "$llama_port")
DROIDSWARM_ADOPT_BLINK_SERVER=$(printf '%q' "$blink_adopt")
DROIDSWARM_ADOPT_BLINK_SERVER_PID=$(printf '%q' "$blink_adopt_pid")
DROIDSWARM_ADOPT_MUX=$(printf '%q' "$mux_adopt")
DROIDSWARM_ADOPT_MUX_PID=$(printf '%q' "$mux_adopt_pid")
DROIDSWARM_ADOPT_LLAMA=$(printf '%q' "$llama_adopt")
DROIDSWARM_ADOPT_LLAMA_PID=$(printf '%q' "$llama_adopt_pid")
DROIDSWARM_LLAMA_MODEL=$(printf '%q' "$llama_model")
DROIDSWARM_SERVICE_CONFIG=$(printf '%q' "$DROIDSWARM_SERVICE_CONFIG")
EOF

  write_env_assignment_file "$state_dir/env.list" "${env_pairs[@]-}"
  write_env_assignment_file "$state_dir/config.list" "${config_pairs[@]-}"
  write_project_metadata \
    "$project_root" \
    "$project_name" \
    "$project_id" \
    "$project_mode" \
    "$main_branch" \
    "$production_branch" \
    "$dashboard_port" \
    "$ws_port" \
    "$db_path"
  write_project_setup_state \
    "$project_root" \
    "$project_name" \
    "$project_id" \
    "$project_mode" \
    "$main_branch" \
    "$production_branch" \
    "$dashboard_port" \
    "$ws_port" \
    "$db_path" \
    "$DROIDSWARM_VERSION" \
    "$specs_dir"

  if [[ "$foreground" == "1" ]]; then
    "$ROOT_DIR/libexec/droidswarm-daemon.sh" "$swarm_id" "$state_dir"
  else
    nohup "$ROOT_DIR/libexec/droidswarm-daemon.sh" "$swarm_id" "$state_dir" >>"$log_file" 2>&1 &
    local pid="$!"
    printf '%s\n' "$pid" >"$(swarm_pid_file "$swarm_id")"
    info "Started DroidSwarm '$swarm_id' (pid $pid)"
    sleep 2
    print_swarm_runtime_status "$swarm_id"
  fi
}

print_swarm_runtime_status() {
  local swarm_id="$1"
  local include_header="${2:-1}"

  if ! load_swarm_env "$swarm_id"; then
    err "Unable to load swarm state for $swarm_id"
    return 1
  fi

  local pid status uptime
  local socket_component_status dashboard_component_status orch_component_status bridge_component_status
  local blink_component_status mux_component_status llama_component_status

  pid="-"
  status="stopped"
  uptime="-"
  socket_component_status="-"
  dashboard_component_status="-"
  orch_component_status="-"
  bridge_component_status="disabled"
  blink_component_status="-"
  mux_component_status="-"
  llama_component_status="-"

  if [[ -f "$(swarm_status_file "$swarm_id")" ]]; then
    status="$(<"$(swarm_status_file "$swarm_id")")"
  fi
  if [[ -f "$(swarm_pid_file "$swarm_id")" ]]; then
    pid="$(<"$(swarm_pid_file "$swarm_id")")"
    if is_pid_running "$pid"; then
      [[ "$status" == "stopped" ]] && status="running"
      uptime="$(format_duration "${DROIDSWARM_CREATED_EPOCH:-0}")"
    else
      [[ "$status" == "running" ]] && status="degraded"
    fi
  fi
  if [[ -f "$(component_status_file "socket-server" "$(swarm_dir "$swarm_id")")" ]]; then
    socket_component_status="$(<"$(component_status_file "socket-server" "$(swarm_dir "$swarm_id")")")"
  fi
  if [[ -f "$(component_status_file "dashboard" "$(swarm_dir "$swarm_id")")" ]]; then
    dashboard_component_status="$(<"$(component_status_file "dashboard" "$(swarm_dir "$swarm_id")")")"
  fi
  if [[ -f "$(component_status_file "orchestrator" "$(swarm_dir "$swarm_id")")" ]]; then
    orch_component_status="$(<"$(component_status_file "orchestrator" "$(swarm_dir "$swarm_id")")")"
  fi
  if [[ -f "$(component_status_file "blink-bridge" "$(swarm_dir "$swarm_id")")" ]]; then
    bridge_component_status="$(<"$(component_status_file "blink-bridge" "$(swarm_dir "$swarm_id")")")"
  fi
  if [[ -f "$(service_status_file "blink-server" "$(swarm_dir "$swarm_id")")" ]]; then
    blink_component_status="$(<"$(service_status_file "blink-server" "$(swarm_dir "$swarm_id")")")"
  fi
  if [[ -f "$(service_status_file "mux" "$(swarm_dir "$swarm_id")")" ]]; then
    mux_component_status="$(<"$(service_status_file "mux" "$(swarm_dir "$swarm_id")")")"
  fi
  if [[ -f "$(service_status_file "llama.cpp" "$(swarm_dir "$swarm_id")")" ]]; then
    llama_component_status="$(<"$(service_status_file "llama.cpp" "$(swarm_dir "$swarm_id")")")"
  fi

  if [[ "$include_header" == "1" ]]; then
    printf '%-28s %-18s %-10s %-8s %-8s %-8s %-12s\n' \
      "SWARM_ID" "PROJECT_ID" "STATUS" "PID" "DASH" "WS" "UPTIME"
  fi
  printf '%-28s %-18s %-10s %-8s %-8s %-8s %-12s\n' \
    "$swarm_id" \
    "${DROIDSWARM_PROJECT_ID:-unknown}" \
    "$status" \
    "$pid" \
    "${DROIDSWARM_DASHBOARD_PORT:-"-"}" \
    "${DROIDSWARM_WS_PORT:-"-"}" \
    "$uptime"
  printf '  components: socket=%s dashboard=%s orchestrator=%s blink-bridge=%s\n' \
    "$socket_component_status" \
    "$dashboard_component_status" \
    "$orch_component_status" \
    "$bridge_component_status"
  printf '  services: blink=%s mux=%s llama=%s\n' \
    "$blink_component_status" \
    "$mux_component_status" \
    "$llama_component_status"
}

project_swarm_ids() {
  local project_root="$1"
  local project_id="$2"
  local exclude_swarm_id="${3:-}"
  local swarm_id candidate_root candidate_id

  for swarm_id in $(active_swarm_ids); do
    [[ -n "$exclude_swarm_id" && "$swarm_id" == "$exclude_swarm_id" ]] && continue
    if ! load_swarm_env "$swarm_id"; then
      continue
    fi

    candidate_root="${DROIDSWARM_PROJECT_ROOT:-}"
    candidate_id="${DROIDSWARM_PROJECT_ID:-}"

    if [[ -n "$project_root" && -n "$candidate_root" && "$candidate_root" == "$project_root" ]]; then
      printf '%s\n' "$swarm_id"
      continue
    fi

    if [[ -n "$project_id" && -n "$candidate_id" && "$candidate_id" == "$project_id" ]]; then
      printf '%s\n' "$swarm_id"
    fi
  done
}

replace_project_swarms() {
  local project_root="$1"
  local project_id="$2"
  local incoming_swarm_id="$3"
  local existing_ids=()
  local existing_id

  for existing_id in $(project_swarm_ids "$project_root" "$project_id" "$incoming_swarm_id"); do
    existing_ids+=("$existing_id")
  done

  if [[ "${#existing_ids[@]}" -eq 0 ]]; then
    return 0
  fi

  info "Replacing existing DroidSwarm instances for project '$project_id'"
  for existing_id in "${existing_ids[@]}"; do
    shutdown_one "$existing_id" || true
    remove_swarm_artifacts "$existing_id"
    info "Removed prior project swarm '$existing_id'"
  done
}

swarm_runtime_status() {
  local swarm_id="$1"
  local pid status

  pid=""
  status="stopped"

  if [[ -f "$(swarm_status_file "$swarm_id")" ]]; then
    status="$(<"$(swarm_status_file "$swarm_id")")"
  fi

  if [[ -f "$(swarm_pid_file "$swarm_id")" ]]; then
    pid="$(<"$(swarm_pid_file "$swarm_id")")"
    if [[ -n "$pid" && "$pid" != "-" ]] && is_pid_running "$pid"; then
      [[ "$status" == "stopped" ]] && status="running"
    else
      [[ "$status" == "running" || "$status" == "starting" ]] && status="degraded"
    fi
  fi

  printf '%s\n' "$status"
}

cmd_list() {
  ensure_runtime_dirs

  local show_all="0"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --all)
        show_all="1"
        ;;
      --help|-h)
        cat <<'EOF'
Usage:
  DroidSwarm list [--all]
EOF
        return 0
        ;;
      *)
        err "Unknown list option: $1"
        return 1
        ;;
    esac
    shift
  done

  printf '%-28s %-18s %-10s %-8s %-8s %-8s %-12s\n' \
    "SWARM_ID" "PROJECT_ID" "STATUS" "PID" "DASH" "WS" "UPTIME"

  local swarm_id pid status uptime
  local found="0"
  for swarm_id in $(active_swarm_ids); do
    if ! load_swarm_env "$swarm_id"; then
      continue
    fi

    pid="-"
    status="stopped"
    uptime="-"

    if [[ -f "$(swarm_status_file "$swarm_id")" ]]; then
      status="$(<"$(swarm_status_file "$swarm_id")")"
    fi

    if [[ -f "$(swarm_pid_file "$swarm_id")" ]]; then
      pid="$(<"$(swarm_pid_file "$swarm_id")")"
      if is_pid_running "$pid"; then
        [[ "$status" == "stopped" ]] && status="running"
        uptime="$(format_duration "${DROIDSWARM_CREATED_EPOCH:-0}")"
      else
        [[ "$status" == "running" ]] && status="degraded"
      fi
    fi

    if [[ "$show_all" != "1" && "$status" != "running" ]]; then
      continue
    fi

    found="1"
    print_swarm_runtime_status "$swarm_id" 0
  done

  if [[ "$found" != "1" ]]; then
    info "No matching DroidSwarm instances found."
  fi
}

cmd_status() {
  ensure_runtime_dirs

  local swarm_id=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --swarm-id)
        shift
        require_value "--swarm-id" "${1:-}"
        swarm_id="$1"
        ;;
      --help|-h)
        print_status_help
        return 0
        ;;
      *)
        err "Unknown status option: $1"
        return 1
        ;;
    esac
    shift
  done

  if ! swarm_id="$(resolve_swarm_id "$swarm_id")"; then
    return 1
  fi

  print_swarm_runtime_status "$swarm_id"
}

cmd_orchestrator_status() {
  ensure_runtime_dirs

  local swarm_id=""
  local task_id=""
  local limit="10"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --swarm-id)
        shift
        require_value "--swarm-id" "${1:-}"
        swarm_id="$1"
        ;;
      --task-id)
        shift
        require_value "--task-id" "${1:-}"
        task_id="$1"
        ;;
      --limit)
        shift
        require_value "--limit" "${1:-}"
        limit="$1"
        ;;
      --help|-h)
        print_orchestrator_help
        return 0
        ;;
      *)
        err "Unknown orchestrator status option: $1"
        print_orchestrator_help
        return 1
        ;;
    esac
    shift
  done

  if ! swarm_id="$(resolve_swarm_id "$swarm_id")"; then
    return 1
  fi

  if ! command -v sqlite3 >/dev/null 2>&1; then
    err "sqlite3 is required for orchestrator status."
    return 1
  fi

  load_swarm_env "$swarm_id" || return 1

  local db_path="${DROIDSWARM_DB_PATH:-}"
  if [[ -z "$db_path" || ! -f "$db_path" ]]; then
    err "Shared project database not found for swarm: $swarm_id"
    return 1
  fi

  info "Swarm: $swarm_id"
  info "Database: $db_path"
  info "Project: ${DROIDSWARM_PROJECT_NAME:-unknown} (${DROIDSWARM_PROJECT_ID:-unknown})"

  if [[ -n "$task_id" ]]; then
    local escaped_task_id
    escaped_task_id="$(sql_escape "$task_id")"

    sqlite3 "$db_path" ".mode box" "
select task_id,name,status,priority,run_id,updated_at,metadata_json
from tasks
where task_id='${escaped_task_id}';

select attempt_id,agent_name,status,created_at,updated_at,metadata_json
from task_attempts
where task_id='${escaped_task_id}'
order by created_at desc
limit ${limit};

select message_id,message_type,sender_name,substr(coalesce(content,''),1,120) as content_preview,created_at
from messages
where task_id='${escaped_task_id}' or channel_id='${escaped_task_id}'
order by created_at desc
limit ${limit};

select event_id,event_type,detail,normalized_verb,created_at
from execution_events
where task_id='${escaped_task_id}'
order by created_at desc
limit ${limit};
"
    return 0
  fi

  sqlite3 "$db_path" ".mode box" "
select run_id,status,created_at,updated_at
from runs
order by created_at desc
limit ${limit};

select task_id,name,status,priority,updated_at
from tasks
order by updated_at desc
limit ${limit};

select attempt_id,task_id,agent_name,status,updated_at
from task_attempts
order by updated_at desc
limit ${limit};
"
}

cmd_orchestrator_message() {
  ensure_runtime_dirs

  local swarm_id=""
  local task_id=""
  local content=""
  local username="operator_cli"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --swarm-id)
        shift
        require_value "--swarm-id" "${1:-}"
        swarm_id="$1"
        ;;
      --task-id)
        shift
        require_value "--task-id" "${1:-}"
        task_id="$1"
        ;;
      --content)
        shift
        require_value "--content" "${1:-}"
        content="$1"
        ;;
      --username)
        shift
        require_value "--username" "${1:-}"
        username="$1"
        ;;
      --help|-h)
        print_orchestrator_help
        return 0
        ;;
      *)
        err "Unknown orchestrator message option: $1"
        print_orchestrator_help
        return 1
        ;;
    esac
    shift
  done

  if [[ -z "$task_id" || -z "$content" ]]; then
    err "Provide --task-id and --content."
    print_orchestrator_help
    return 1
  fi

  if ! command -v curl >/dev/null 2>&1; then
    err "curl is required for orchestrator message."
    return 1
  fi

  if ! swarm_id="$(resolve_swarm_id "$swarm_id")"; then
    return 1
  fi

  load_swarm_env "$swarm_id" || return 1

  local dashboard_port="${DROIDSWARM_DASHBOARD_PORT:-}"
  if [[ -z "$dashboard_port" ]]; then
    err "Dashboard port not found for swarm: $swarm_id"
    return 1
  fi

  curl -sS -X POST \
    "http://127.0.0.1:${dashboard_port}/api/channels/${task_id}/messages" \
    -H 'Content-Type: application/json' \
    --data "{\"username\":\"$(json_escape "$username")\",\"content\":\"$(json_escape "$content")\"}"
  printf '\n'
}

cmd_orchestrator() {
  ensure_runtime_dirs

  local action="${1:-status}"
  if [[ $# -gt 0 ]]; then
    shift
  fi

  case "$action" in
    status)
      cmd_orchestrator_status "$@"
      ;;
    message|send)
      cmd_orchestrator_message "$@"
      ;;
    --help|-h|help)
      print_orchestrator_help
      ;;
    *)
      err "Unknown orchestrator command: $action"
      print_orchestrator_help
      return 1
      ;;
  esac
}

cmd_update() {
  ensure_runtime_dirs

  local repo_url ref install_root bin_dir
  local force
  repo_url=""
  ref=""
  force="0"
  install_root="${DROIDSWARM_INSTALL_ROOT:-$HOME/.droidswarm/install}"
  bin_dir="${DROIDSWARM_BIN_DIR:-$HOME/.local/bin}"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --repo-url)
        shift
        require_value "--repo-url" "${1:-}"
        repo_url="$1"
        ;;
      --ref)
        shift
        require_value "--ref" "${1:-}"
        ref="$1"
        ;;
      --install-root)
        shift
        require_value "--install-root" "${1:-}"
        install_root="$1"
        ;;
      --bin-dir)
        shift
        require_value "--bin-dir" "${1:-}"
        bin_dir="$1"
        ;;
      --force)
        force="1"
        ;;
      --help|-h)
        print_update_help
        return 0
        ;;
      *)
        err "Unknown update option: $1"
        print_update_help
        return 1
        ;;
    esac
    shift
  done

  local script_path="$ROOT_DIR/scripts/update-droidswarm.sh"
  if [[ ! -x "$script_path" ]]; then
    err "Update script not found: $script_path"
    return 1
  fi

  local -a update_cmd=("/bin/bash" "$script_path")
  [[ -n "$repo_url" ]] && update_cmd+=(--repo-url "$repo_url")
  [[ -n "$ref" ]] && update_cmd+=(--ref "$ref")
  [[ "$force" == "1" ]] && update_cmd+=(--force)

  DROIDSWARM_INSTALL_ROOT="$install_root" \
    DROIDSWARM_BIN_DIR="$bin_dir" \
    DROIDSWARM_DEFAULT_REPO_URL="${repo_url:-https://github.com/Quick-Draw-Development/DroidSwarm}" \
    "${update_cmd[@]}"
}

cmd_repair() {
  ensure_runtime_dirs

  local repo_url ref install_root bin_dir
  local clean_reinstall no_restart
  repo_url=""
  ref=""
  clean_reinstall="0"
  no_restart="0"
  install_root="${DROIDSWARM_INSTALL_ROOT:-$HOME/.droidswarm/install}"
  bin_dir="${DROIDSWARM_BIN_DIR:-$HOME/.local/bin}"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --repo-url)
        shift
        require_value "--repo-url" "${1:-}"
        repo_url="$1"
        ;;
      --ref)
        shift
        require_value "--ref" "${1:-}"
        ref="$1"
        ;;
      --install-root)
        shift
        require_value "--install-root" "${1:-}"
        install_root="$1"
        ;;
      --bin-dir)
        shift
        require_value "--bin-dir" "${1:-}"
        bin_dir="$1"
        ;;
      --clean)
        clean_reinstall="1"
        ;;
      --no-restart)
        no_restart="1"
        ;;
      --help|-h)
        print_repair_help
        return 0
        ;;
      *)
        err "Unknown repair option: $1"
        print_repair_help
        return 1
        ;;
    esac
    shift
  done

  local script_path="$ROOT_DIR/scripts/repair-droidswarm.sh"
  if [[ ! -x "$script_path" ]]; then
    err "Repair script not found: $script_path"
    return 1
  fi

  local -a repair_cmd=("/bin/bash" "$script_path")
  [[ -n "$repo_url" ]] && repair_cmd+=(--repo-url "$repo_url")
  [[ -n "$ref" ]] && repair_cmd+=(--ref "$ref")
  [[ "$clean_reinstall" == "1" ]] && repair_cmd+=(--clean)
  [[ "$no_restart" == "1" ]] && repair_cmd+=(--no-restart)

  DROIDSWARM_INSTALL_ROOT="$install_root" \
    DROIDSWARM_BIN_DIR="$bin_dir" \
    DROIDSWARM_DEFAULT_REPO_URL="${repo_url:-https://github.com/Quick-Draw-Development/DroidSwarm}" \
    "${repair_cmd[@]}"
}

remove_swarm_artifacts() {
  local swarm_id="$1"
  local state_dir
  state_dir="$(swarm_dir "$swarm_id")"

  rm -rf "$state_dir"
  rm -f \
    "$(swarm_log_file "$swarm_id")" \
    "$(component_log_file "$swarm_id" "socket-server")" \
    "$(component_log_file "$swarm_id" "dashboard")" \
    "$(component_log_file "$swarm_id" "orchestrator")" \
    "$(component_log_file "$swarm_id" "blink-bridge")" \
    "$(component_log_file "$swarm_id" "worker-host")" \
    "$(component_log_file "$swarm_id" "blink-server")" \
    "$(component_log_file "$swarm_id" "mux")" \
    "$(component_log_file "$swarm_id" "llama.cpp")"
}

cmd_cleanup() {
  ensure_runtime_dirs

  local swarm_id=""
  local cleanup_all="0"
  local shutdown_running="0"
  local removed_count="0"
  local skipped_count="0"
  local found_count="0"
  local target_ids=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --swarm-id)
        shift
        require_value "--swarm-id" "${1:-}"
        swarm_id="$1"
        ;;
      --all)
        cleanup_all="1"
        ;;
      --shutdown-running)
        shutdown_running="1"
        ;;
      --help|-h)
        print_cleanup_help
        return 0
        ;;
      *)
        err "Unknown cleanup option: $1"
        print_cleanup_help
        return 1
        ;;
    esac
    shift
  done

  if [[ -n "$swarm_id" && "$cleanup_all" == "1" ]]; then
    err "Use either --swarm-id or --all, not both."
    return 1
  fi

  if [[ -n "$swarm_id" ]]; then
    if ! swarm_exists "$swarm_id"; then
      err "Unknown swarm: $swarm_id"
      return 1
    fi
    target_ids=("$swarm_id")
  else
    local id
    for id in $(active_swarm_ids); do
      target_ids+=("$id")
    done
  fi

  if [[ "${#target_ids[@]}" -eq 0 ]]; then
    info "No DroidSwarm instances found."
    return 0
  fi

  local id runtime_status
  for id in "${target_ids[@]}"; do
    found_count=$((found_count + 1))
    runtime_status="$(swarm_runtime_status "$id")"

    if [[ "$runtime_status" == "running" || "$runtime_status" == "starting" ]]; then
      if [[ "$shutdown_running" == "1" ]]; then
        shutdown_one "$id"
        runtime_status="$(swarm_runtime_status "$id")"
      else
        info "Skipping active swarm '$id' (status: $runtime_status). Re-run with --shutdown-running to remove it."
        skipped_count=$((skipped_count + 1))
        continue
      fi
    fi

    if [[ "$cleanup_all" != "1" && -z "$swarm_id" ]]; then
      case "$runtime_status" in
        stopped|failed|degraded)
          ;;
        *)
          info "Skipping swarm '$id' (status: $runtime_status)."
          skipped_count=$((skipped_count + 1))
          continue
          ;;
      esac
    fi

    remove_swarm_artifacts "$id"
    info "Removed DroidSwarm '$id'"
    removed_count=$((removed_count + 1))
  done

  if [[ "$found_count" -gt 0 && "$removed_count" -eq 0 ]]; then
    info "No matching stopped or failed swarms were removed."
  fi

  info "Cleanup complete. removed=$removed_count skipped=$skipped_count"
}

shutdown_one() {
  local swarm_id="$1"
  if ! swarm_exists "$swarm_id"; then
    err "Unknown swarm: $swarm_id"
    return 1
  fi

  local pid=""
  if [[ -f "$(swarm_pid_file "$swarm_id")" ]]; then
    pid="$(<"$(swarm_pid_file "$swarm_id")")"
  fi

  local state_dir
  state_dir="$(swarm_dir "$swarm_id")"

  if [[ -n "$pid" && "$pid" != "-" ]] && is_pid_running "$pid"; then
    kill "$pid"
    local waited=0
    while is_pid_running "$pid" && [[ "$waited" -lt 10 ]]; do
      sleep 1
      waited=$((waited + 1))
    done
    if is_pid_running "$pid"; then
      kill -9 "$pid" 2>/dev/null || true
    fi
  fi

  for component in orchestrator dashboard socket-server; do
    local component_pid_path
    component_pid_path="$(component_pid_file "$component" "$state_dir")"
    if [[ ! -f "$component_pid_path" ]]; then
      continue
    fi
    local component_pid
    component_pid="$(<"$component_pid_path")"
    if [[ -n "$component_pid" && "$component_pid" != "-" ]] && is_pid_running "$component_pid"; then
      kill "$component_pid" 2>/dev/null || true
      sleep 1
      if is_pid_running "$component_pid"; then
        kill -9 "$component_pid" 2>/dev/null || true
      fi
    fi
  done

  for service in blink-server mux llama.cpp; do
    local service_pid_path
    service_pid_path="$(service_pid_file "$service" "$state_dir")"
    if [[ ! -f "$service_pid_path" ]]; then
      continue
    fi
    local service_pid
    service_pid="$(<"$service_pid_path")"
    if [[ -n "$service_pid" && "$service_pid" != "-" ]] && is_pid_running "$service_pid"; then
      kill "$service_pid" 2>/dev/null || true
      sleep 1
      if is_pid_running "$service_pid"; then
        kill -9 "$service_pid" 2>/dev/null || true
      fi
    fi
  done

  printf 'stopped\n' >"$(swarm_status_file "$swarm_id")"
  info "Stopped DroidSwarm '$swarm_id'"
}

cmd_shutdown() {
  ensure_runtime_dirs

  local swarm_id=""
  local all="0"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --swarm-id)
        shift
        require_value "--swarm-id" "${1:-}"
        swarm_id="$1"
        ;;
      --all)
        all="1"
        ;;
      --help|-h)
        cat <<'EOF'
Usage:
  DroidSwarm shutdown --swarm-id <id>
  DroidSwarm shutdown --all
EOF
        return 0
        ;;
      *)
        err "Unknown shutdown option: $1"
        return 1
        ;;
    esac
    shift
  done

  if [[ "$all" != "1" && -z "$swarm_id" ]]; then
    err "Provide --swarm-id or --all"
    return 1
  fi

  if [[ "$all" == "1" ]]; then
    local id
    for id in $(active_swarm_ids); do
      shutdown_one "$id" || true
    done
  else
    shutdown_one "$swarm_id"
  fi
}

case "$COMMAND" in
  setup)
    cmd_setup "$@"
    ;;
  swarm)
    cmd_swarm "$@"
    ;;
  orchestrator)
    cmd_orchestrator "$@"
    ;;
  update)
    cmd_update "$@"
    ;;
  repair)
    cmd_repair "$@"
    ;;
  list)
    cmd_list "$@"
    ;;
  status)
    cmd_status "$@"
    ;;
  shutdown)
    cmd_shutdown "$@"
    ;;
  cleanup)
    cmd_cleanup "$@"
    ;;
  version)
    print_version
    ;;
  help|-h|--help)
    print_help
    ;;
  *)
    err "Unknown command: $COMMAND"
    print_help
    exit 1
    ;;
esac
