{
  "name": "federation-adb",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "root": "packages/federation-adb",
  "sourceRoot": "packages/federation-adb/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p packages/federation-adb/tsconfig.json"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --noEmit -p packages/federation-adb/tsconfig.json"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --noEmit -p packages/federation-adb/tsconfig.json"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node --import tsx --test packages/federation-adb/src/**/*.spec.ts"
      }
    }
  },
  "tags": []
}
