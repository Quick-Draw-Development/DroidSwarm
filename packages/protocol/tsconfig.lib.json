{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "../../dist/packages/protocol/src",
    "rootDir": "src",
    "sourceMap": true,
    "declaration": false,
    "composite": false,
    "tsBuildInfoFile": "../../dist/packages/protocol/tsconfig.lib.tsbuildinfo",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true
  },
  "include": [
    "src/**/*"
  ]
}
