{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2015",
    "module": "esnext",
    "lib": [
      "es2020",
      "dom"
    ],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "baseUrl": ".",
    "paths": {
    "@protocol": [
      "packages/protocol/src"
    ],
    "@protocol/*": [
      "packages/protocol/src/*"
    ],
    "@protocol-alias": [
      "packages/protocol-alias/src"
    ],
    "@protocol-alias/*": [
      "packages/protocol-alias/src/*"
    ],
    "bootstrap": [
      "packages/bootstrap/src/index.ts"
    ],
    "@shared-types": [
      "packages/shared-types/src/index.ts"
    ],
    "@shared-workers": [
      "packages/shared-workers/src/index.ts"
    ],
    "@shared-routing": [
      "packages/shared-routing/src/index.ts"
    ],
    "@shared-git": [
      "packages/shared-git/src/index.ts"
    ],
    "@shared-memory": [
      "packages/shared-memory/src/index.ts"
    ],
    "@shared-agent-brain": [
      "packages/shared-agent-brain/src/index.ts"
    ],
    "@shared-agent-brain/*": [
      "packages/shared-agent-brain/src/*"
    ],
    "@shared-projects": [
      "packages/shared-projects/src/index.ts"
    ],
    "@shared-models": [
      "packages/shared-models/src/index.ts"
    ],
    "@shared-models/*": [
      "packages/shared-models/src/*"
    ],
    "@mythos-engine": [
      "packages/mythos-engine/src/index.ts"
    ],
    "@mythos-engine/*": [
      "packages/mythos-engine/src/*"
    ],
    "@model-router": [
      "packages/model-router/src/index.ts"
    ],
    "@shared-chat": [
      "packages/shared-chat/src/index.ts"
    ],
    "@shared-skills": [
      "packages/shared-skills/src/index.ts"
    ],
    "@shared-skills/*": [
      "packages/shared-skills/src/*"
    ],
    "@shared-config": [
      "packages/shared-config/src/index.ts"
    ],
    "@shared-droidspeak": [
      "packages/shared-droidspeak/src/index.ts"
    ],
    "@shared-governance": [
      "packages/shared-governance/src/index.ts"
    ],
    "@shared-governance/*": [
      "packages/shared-governance/src/*"
    ],
    "@shared-persistence": [
      "packages/shared-persistence/src/index.ts"
    ],
    "@shared-tracing": [
      "packages/shared-tracing/src/index.ts"
    ],
    "@shared-llm": [
      "packages/shared-llm/src/index.ts"
    ],
    "@shared-codex": [
      "packages/shared-codex/src/index.ts"
    ],
    "@federation-bus": [
      "packages/federation-bus/src/index.ts"
    ],
    "@federation-bus/*": [
      "packages/federation-bus/src/*"
    ],
    "@federation-adb": [
      "packages/federation-adb/src/index.ts"
    ],
    "@federation-adb/*": [
      "packages/federation-adb/src/*"
    ]
    }
  },
  "exclude": [
    "node_modules",
    "tmp"
  ]
}
