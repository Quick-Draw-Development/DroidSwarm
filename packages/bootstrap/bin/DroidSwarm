  DroidSwarm slack restart --swarm-id <id>
EOF
}

resolve_runtime_value() {
  local env_value="$1"
  shift

  if [[ -n "$env_value" && -f "$env_value" ]]; then
    printf '%s\n' "$env_value"
    return 0
  fi

  local candidate
  for candidate in "$@"; do
    if [[ -n "$candidate" && -f "$candidate" ]]; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done

  return 1
}

resolve_runtime_dir_value() {
  local env_value="$1"
  shift

  if [[ -n "$env_value" && -d "$env_value" ]]; then
    printf '%s\n' "$env_value"
    return 0
  fi

  local candidate
  for candidate in "$@"; do
    if [[ -n "$candidate" && -d "$candidate" ]]; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done

  return 1
}

resolve_swarm_id() {
  local swarm_id="${1:-}"
  if [[ -n "$swarm_id" ]]; then
    if ! swarm_exists "$swarm_id"; then
      err "Unknown swarm: $swarm_id"
      return 1
    fi
    printf '%s\n' "$swarm_id"
    return 0
  fi

  local detected_ids=()
  local active_id
  for active_id in $(active_swarm_ids); do
    detected_ids+=("$active_id")
  done

  if [[ "${#detected_ids[@]}" -eq 0 ]]; then
    err "No DroidSwarm instances found."
    return 1
  fi

  if [[ "${#detected_ids[@]}" -gt 1 ]]; then
    err "Multiple swarms found. Re-run with --swarm-id."
    cmd_list --all
    return 1
  fi

  printf '%s\n' "${detected_ids[0]}"
}

sql_escape() {
  local value="${1:-}"
  printf "%s" "${value//\'/\'\'}"
}

resolve_repair_script_path() {
  local candidate
  for candidate in \
    "$ROOT_DIR/scripts/repair-droidswarm.sh" \
    "$ROOT_DIR/bin/repair-droidswarm"; do
    if [[ -x "$candidate" ]]; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done

  return 1
}

service_runtime_config_is_valid() {
  local config_file="${1:-$DROIDSWARM_SERVICE_CONFIG}"

  [[ -f "$config_file" ]] || return 1
  /bin/bash -n "$config_file" >/dev/null 2>&1 || return 1

  env -i DROIDSWARM_SERVICE_CONFIG="$config_file" /bin/bash -lc '
    set -euo pipefail
    source "$DROIDSWARM_SERVICE_CONFIG"
    [[ -n "${DROIDSWARM_LLAMA_SERVER_BIN:-}" ]]
    [[ -n "${DROIDSWARM_LLAMA_MODEL:-}" ]]
    [[ -x "${DROIDSWARM_LLAMA_SERVER_BIN:-}" ]]
    [[ -f "${DROIDSWARM_LLAMA_MODEL:-}" ]]
  ' >/dev/null 2>&1
}

ensure_service_runtime_ready() {
  local repair_script=""
  local install_root="${DROIDSWARM_INSTALL_ROOT:-$DROIDSWARM_HOME/install}"
  local bin_dir="${DROIDSWARM_BIN_DIR:-$HOME/.local/bin}"

  if service_runtime_config_is_valid "$DROIDSWARM_SERVICE_CONFIG"; then
    return 0
  fi

  info "Local DroidSwarm service runtime is missing or invalid. Attempting automatic repair."
  repair_script="$(resolve_repair_script_path)" || {
    err "Unable to locate repair script for automatic service recovery."
    return 1
  }

  DROIDSWARM_INSTALL_ROOT="$install_root" \
    DROIDSWARM_BIN_DIR="$bin_dir" \
    DROIDSWARM_HOME="$DROIDSWARM_HOME" \
    /bin/bash "$repair_script" --no-restart

  if ! service_runtime_config_is_valid "$DROIDSWARM_SERVICE_CONFIG"; then
    err "Automatic service repair completed, but the runtime configuration is still invalid."
    return 1
  fi
}

service_listener_is_adoptable() {
  local service_name="$1"
  local port="$2"
  local expected_bin="$3"
  shift 3

  local listener_pid="" command_line="" expected_name="" token=""
  listener_pid="$(listener_pid_for_port "$port" || true)"
  [[ -n "$listener_pid" ]] || return 1

  command_line="$(command_line_for_pid "$listener_pid" || true)"
  [[ -n "$command_line" ]] || return 1

  expected_name="$(basename "$expected_bin")"
  command_line="$(printf '%s' "$command_line" | tr '[:upper:]' '[:lower:]')"
  expected_name="$(printf '%s' "$expected_name" | tr '[:upper:]' '[:lower:]')"

  if [[ "$service_name" == "llama.cpp" ]]; then
    if [[ -n "$expected_name" && "$command_line" == *"$expected_name"* ]]; then
      if llama_service_looks_compatible "$port"; then
        return 0
      fi
      return 1
    fi
  else
    if [[ -n "$expected_name" && "$command_line" == *"$expected_name"* ]]; then
      return 0
    fi

    for token in "$@"; do
      token="$(printf '%s' "$token" | tr '[:upper:]' '[:lower:]')"
      if [[ -n "$token" && "$command_line" == *"$token"* ]]; then
        return 0
      fi
    done
  fi

  local swarm_id candidate_pid candidate_port
  for swarm_id in $(active_swarm_ids); do
    if ! load_swarm_env "$swarm_id"; then
      continue
    fi

    case "$service_name" in
      llama.cpp)
        candidate_port="${DROIDSWARM_LLAMA_PORT:-}"
        ;;
      *)
        candidate_port=""
        ;;
    esac

    [[ "$candidate_port" == "$port" ]] || continue
    candidate_pid=""
    if [[ -f "$(service_pid_file "$service_name" "$(swarm_dir "$swarm_id")")" ]]; then
      candidate_pid="$(<"$(service_pid_file "$service_name" "$(swarm_dir "$swarm_id")")")"
    fi
    if [[ -n "$candidate_pid" && "$candidate_pid" == "$listener_pid" ]]; then
      if [[ "$service_name" != "llama.cpp" ]] || llama_service_looks_compatible "$port"; then
        return 0
      fi
    fi
  done

  return 1
}

llama_service_looks_compatible() {
  local port="$1"
  local base_url="http://127.0.0.1:${port}"

  if ! port_is_listening "$port"; then
    return 1
  fi

  if http_probe "${base_url}/v1/models" 2; then
    return 0
  fi

  if http_post_json_probe "${base_url}/completion" '{"prompt":"health","n_predict":1}' 3; then
    return 0
  fi

  if http_post_json_probe "${base_url}/v1/completions" '{"model":"default","prompt":"health","max_tokens":1}' 3; then
    return 0
  fi

  return 1
}

resolve_service_binding() {
  local service_name="$1"
  local requested_port="$2"
  local explicit_flag="$3"
  local default_port="$4"
  local expected_bin="$5"
  shift 5

  local listener_pid=""
  if port_is_free "$requested_port"; then
    printf 'use|%s|\n' "$requested_port"
    return 0
  fi

  listener_pid="$(listener_pid_for_port "$requested_port" || true)"
  if service_listener_is_adoptable "$service_name" "$requested_port" "$expected_bin" "$@"; then
    printf 'adopt|%s|%s\n' "$requested_port" "$listener_pid"
    return 0
  fi

  if [[ "$explicit_flag" == "1" ]]; then
    err "$service_name port is already in use: $requested_port"
    return 1
  fi

  printf 'use|%s|\n' "$(next_available_port "$default_port")"
}


write_project_metadata() {
  local project_root="$1"
  local project_name="$2"
  local project_id="$3"
  local project_mode="$4"
  local main_branch="$5"
  local production_branch="$6"
  local dashboard_port="$7"
  local ws_port="$8"
  local db_path="$9"

  local meta_dir meta_file
  meta_dir="$(project_meta_dir "$project_root")"
  meta_file="$(project_meta_file "$project_root")"

  mkdir -p "$meta_dir"

  cat >"$meta_file" <<EOF
{
  "project_name": "$(json_escape "$project_name")",
  "project_id": "$(json_escape "$project_id")",
  "project_mode": "$(json_escape "$project_mode")",
  "main_branch": "$(json_escape "$main_branch")",
  "production_branch": "$(json_escape "$production_branch")",
  "db_path": "$(json_escape "$db_path")",
  "dashboard_port": $dashboard_port,
  "ws_port": $ws_port
}
EOF
}

write_project_setup_state() {
  local project_root="$1"
  local project_name="$2"
  local project_id="$3"
  local project_mode="$4"
  local main_branch="$5"
  local production_branch="$6"
  local dashboard_port="$7"
  local ws_port="$8"
  local db_path="$9"
  local version="${10:-${DROIDSWARM_VERSION:-}}"
  local spec_dir="${11:-}"
  local federation_enabled="${12:-0}"
  local federation_adb_enabled="${13:-0}"
  local federation_peers="${14:-}"
  local federation_remote_workers_file="${15:-}"
  local slack_bot_enabled="${16:-0}"

  cat >"$(project_setup_file "$project_root")" <<EOF
DROIDSWARM_PROJECT_ROOT=$(printf '%q' "$project_root")
DROIDSWARM_PROJECT_NAME=$(printf '%q' "$project_name")
DROIDSWARM_PROJECT_ID=$(printf '%q' "$project_id")
DROIDSWARM_PROJECT_MODE=$(printf '%q' "$project_mode")
DROIDSWARM_MAIN_BRANCH=$(printf '%q' "$main_branch")
DROIDSWARM_PRODUCTION_BRANCH=$(printf '%q' "$production_branch")
DROIDSWARM_DASHBOARD_PORT=$(printf '%q' "$dashboard_port")
DROIDSWARM_WS_PORT=$(printf '%q' "$ws_port")
DROIDSWARM_DB_PATH=$(printf '%q' "$db_path")
DROIDSWARM_VERSION=$(printf '%q' "$version")
DROIDSWARM_SPECS_DIR=$(printf '%q' "$spec_dir")
DROIDSWARM_ENABLE_FEDERATION=$(printf '%q' "$federation_enabled")
DROIDSWARM_ENABLE_FEDERATION_ADB=$(printf '%q' "$federation_adb_enabled")
DROIDSWARM_FEDERATION_PEERS=$(printf '%q' "$federation_peers")
DROIDSWARM_FEDERATION_REMOTE_WORKERS_FILE=$(printf '%q' "$federation_remote_workers_file")
DROIDSWARM_ENABLE_SLACK_BOT=$(printf '%q' "$slack_bot_enabled")
DROIDSWARM_SETUP_COMPLETED_AT=$(printf '%q' "$(now_utc)")
EOF
}

load_project_setup() {
  local project_root="$1"
  local setup_file
  setup_file="$(project_setup_file "$project_root")"
  if [[ ! -f "$setup_file" ]]; then
    return 1
  fi

  # shellcheck disable=SC1090
  source "$setup_file"
}

cmd_setup() {
  ensure_runtime_dirs

  local project_root project_name project_id project_mode main_branch production_branch
  local dashboard_port ws_port db_path force specs_dir
  local federation_enabled federation_adb_enabled federation_peers federation_remote_workers_file
  local slack_bot_enabled
  project_root="$(pwd)"
  project_name=""
  project_id=""
  project_mode=""
  main_branch=""
  production_branch="production"
  dashboard_port=""
  ws_port=""
  db_path=""
  force="0"
  specs_dir="$ROOT_DIR/specs"
  federation_enabled="${DROIDSWARM_ENABLE_FEDERATION:-0}"
  federation_adb_enabled="${DROIDSWARM_ENABLE_FEDERATION_ADB:-0}"
  federation_peers="${DROIDSWARM_FEDERATION_PEERS:-}"
  federation_remote_workers_file="${DROIDSWARM_FEDERATION_REMOTE_WORKERS_FILE:-}"
  slack_bot_enabled="${DROIDSWARM_ENABLE_SLACK_BOT:-0}"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --project-root)
        shift
        require_value "--project-root" "${1:-}"
        project_root="$1"
        ;;
      --project-mode)
        shift
        require_value "--project-mode" "${1:-}"
        project_mode="$1"
        ;;
      --project-name)
        shift
        require_value "--project-name" "${1:-}"
        project_name="$1"
        ;;
      --project-id)
        shift
        require_value "--project-id" "${1:-}"
        project_id="$1"
        ;;
      --main-branch)
        shift
        require_value "--main-branch" "${1:-}"
        main_branch="$1"
        ;;
      --production-branch)
        shift
        require_value "--production-branch" "${1:-}"
        production_branch="$1"
        ;;
      --dashboard-port)
        shift
        require_value "--dashboard-port" "${1:-}"
        dashboard_port="$1"
        ;;
      --ws-port)
        shift
        require_value "--ws-port" "${1:-}"
        ws_port="$1"
        ;;
      --db-path)
        shift
        require_value "--db-path" "${1:-}"
        db_path="$1"
        ;;
      --enable-federation)
        federation_enabled="1"
        ;;
      --enable-federation-adb)
        federation_enabled="1"
        federation_adb_enabled="1"
        ;;
      --enable-slack-bot)
        slack_bot_enabled="1"
        ;;
      --federation-peer)
        shift
        require_value "--federation-peer" "${1:-}"
        if [[ -n "$federation_peers" ]]; then
          federation_peers="${federation_peers},$1"
        else
          federation_peers="$1"
        fi
        ;;
      --federation-remote-workers-file)
        shift
        require_value "--federation-remote-workers-file" "${1:-}"
        federation_remote_workers_file="$1"
        ;;
      --force)
        force="1"
        ;;
      --help|-h)
        print_setup_help
        return 0
        ;;
      *)
        err "Unknown setup option: $1"
        print_setup_help
        return 1
        ;;
    esac
    shift
  done

  mkdir -p "$project_root"
  project_root="$(cd "$project_root" && pwd)"

  if [[ "$force" != "1" ]] && project_is_setup "$project_root"; then
    err "Project is already set up: $project_root"
    err "Use --force to regenerate setup metadata."
    return 1
  fi

  if [[ -z "$project_mode" ]]; then
    err "Missing required option: --project-mode"
    err "Allowed values: greenfield | existing"
    return 1
  fi

  case "$project_mode" in
    greenfield|existing)
      ;;
    *)
      err "Invalid --project-mode: $project_mode"
      err "Allowed values: greenfield | existing"
      return 1
      ;;
  esac

  if [[ -z "$project_name" ]]; then
    project_name="$(read_package_name "$project_root" || true)"
  fi

  if [[ -z "$project_name" ]]; then
    project_name="$(git_repo_name "$project_root" || true)"
  fi

  if [[ -z "$project_name" ]]; then
    project_name="$(basename "$project_root")"
  fi

  if [[ -z "$project_id" ]]; then
    project_id="$(slugify "$project_name")"
  fi

  if [[ -z "$main_branch" ]]; then
    main_branch="$(detect_main_branch "$project_root")"
  fi

  if [[ -z "$dashboard_port" ]]; then
    dashboard_port="$(next_available_port 3000)"
  fi

  if [[ -z "$ws_port" ]]; then
    ws_port="$(next_available_port 8765)"
    if [[ "$ws_port" == "$dashboard_port" ]]; then
      ws_port=$((ws_port + 1))
    fi
  fi

  if [[ -z "$db_path" ]]; then
    db_path="$(project_db_file "$project_root")"
  fi

  mkdir -p "$(dirname "$db_path")"
  touch "$db_path"
  mkdir -p "$(project_meta_dir "$project_root")"

  write_project_metadata \
    "$project_root" \
    "$project_name" \
    "$project_id" \
    "$project_mode" \
    "$main_branch" \
    "$production_branch" \
    "$dashboard_port" \
    "$ws_port" \
    "$db_path"

  write_project_setup_state \
    "$project_root" \
    "$project_name" \
    "$project_id" \
    "$project_mode" \
    "$main_branch" \
    "$production_branch" \
    "$dashboard_port" \
    "$ws_port" \
    "$db_path" \
    "$DROIDSWARM_VERSION" \
    "$specs_dir" \
    "$federation_enabled" \
    "$federation_adb_enabled" \
    "$federation_peers" \
    "$federation_remote_workers_file" \
    "$slack_bot_enabled"

  run_shared_projects_cli onboard \
    --project-root "$project_root" \
    --project-id "$project_id" \
    --project-name "$project_name" \
    --db-path "$db_path" >/dev/null

  ensure_gitignore_entry "$project_root" ".droidswarm/*"
  ensure_gitignore_entry "$project_root" "!.droidswarm/.gitkeep"
  touch "$(project_meta_dir "$project_root")/.gitkeep"

  info "Initialized DroidSwarm project setup."
  info "Project root: $project_root"
  info "Project: $project_name ($project_id)"
  info "Project mode: $project_mode"
  info "Main branch: $main_branch"
  info "Production branch: $production_branch"
  info "Metadata: $(project_meta_file "$project_root")"
  info "Database: $db_path"
  info "Federation: $( [[ "$federation_enabled" == "1" ]] && printf 'enabled' || printf 'disabled' )"
  info "Slack bot: $( [[ "$slack_bot_enabled" == "1" ]] && printf 'enabled' || printf 'disabled' )"
  info "Registered project in global registry."
}

cmd_swarm() {
  ensure_runtime_dirs

  local project_root project_name project_id project_mode project_lookup swarm_id dashboard_port ws_port db_path
  local agent_count main_branch production_branch repo_url foreground dry_run
  local debug_enabled debug_explicit
  local dashboard_port_explicit ws_port_explicit
  local llama_port_explicit
  local node_bin operator_token socket_server_entry orchestrator_entry dashboard_server_entry
  local worker_host_entry
  local slack_bot_entry
  local dashboard_static_dir dashboard_public_dir dashboard_workdir
  local specs_dir
  local llama_port llama_model
  local enable_slack_bot slack_bot_explicit
  project_root="$(pwd)"
  project_name=""
  project_id=""
  project_mode=""
  project_lookup=""
  swarm_id=""
  dashboard_port=""
  ws_port=""
  db_path=""
  agent_count="0"
  main_branch="main"
  production_branch="production"
  repo_url=""
  foreground="0"
  dry_run="0"
  debug_enabled="${DROIDSWARM_DEBUG:-}"
  debug_explicit="0"
  dashboard_port_explicit="0"
  ws_port_explicit="0"
  llama_port_explicit="0"
  node_bin="${DROIDSWARM_NODE_BIN:-$(command -v node || true)}"
  operator_token="${DROIDSWARM_OPERATOR_TOKEN:-}"
  enable_slack_bot="${DROIDSWARM_ENABLE_SLACK_BOT:-0}"
  slack_bot_explicit="0"
  enable_federation="${DROIDSWARM_ENABLE_FEDERATION:-0}"
  swarm_role="${DROIDSWARM_SWARM_ROLE:-master}"
  federation_connect_to="${DROIDSWARM_FEDERATION_CONNECT_TO:-}"
  federation_bus_port="${DROIDSWARM_FEDERATION_BUS_PORT:-}"
  federation_admin_port="${DROIDSWARM_FEDERATION_ADMIN_PORT:-}"
  federation_node_id="${DROIDSWARM_FEDERATION_NODE_ID:-}"
  federation_host="${DROIDSWARM_FEDERATION_HOST:-127.0.0.1}"
  federation_bus_url="${DROIDSWARM_FEDERATION_BUS_URL:-}"
  federation_admin_url="${DROIDSWARM_FEDERATION_ADMIN_URL:-}"
  federation_peers="${DROIDSWARM_FEDERATION_PEERS:-}"
  federation_remote_workers_file="${DROIDSWARM_FEDERATION_REMOTE_WORKERS_FILE:-}"
  federation_bus_entry="${DROIDSWARM_FEDERATION_BUS_ENTRY:-}"
  federation_adb_enabled="${DROIDSWARM_ENABLE_FEDERATION_ADB:-0}"
  federation_adb_port="${DROIDSWARM_FEDERATION_ADB_PORT:-}"
  federation_adb_bin="${DROIDSWARM_FEDERATION_ADB_BIN:-adb}"
  federation_adb_entry="${DROIDSWARM_FEDERATION_ADB_ENTRY:-}"
  federation_adopt="0"
  federation_adopt_pid=""
  socket_server_entry=""
  orchestrator_entry=""
  dashboard_server_entry=""
  dashboard_static_dir=""
  dashboard_public_dir=""
  dashboard_workdir=""
  worker_host_entry=""
  slack_bot_entry=""
  llama_port=""
  llama_model="${DROIDSWARM_LLAMA_MODEL:-}"

  local -a env_pairs=()
  local -a config_pairs=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --swarm-id)
        shift
        require_value "--swarm-id" "${1:-}"
        swarm_id="$1"
        ;;
      --project-root)
        shift
        require_value "--project-root" "${1:-}"
        project_root="$1"
        ;;
      --project)
        shift
        require_value "--project" "${1:-}"
        project_lookup="$1"
        ;;
      --project-name)
        shift
        require_value "--project-name" "${1:-}"
        project_name="$1"
        ;;
      --project-id)
        shift
        require_value "--project-id" "${1:-}"
        project_id="$1"
        ;;
      --dashboard-port)
        shift
        require_value "--dashboard-port" "${1:-}"
        dashboard_port="$1"
        dashboard_port_explicit="1"
        ;;
      --ws-port)
        shift
        require_value "--ws-port" "${1:-}"
        ws_port="$1"
        ws_port_explicit="1"
        ;;
      --agent-count)
        shift
        require_value "--agent-count" "${1:-}"
        agent_count="$1"
        ;;
      --main-branch)
        shift
        require_value "--main-branch" "${1:-}"
        main_branch="$1"
        ;;
      --production-branch)
        shift
        require_value "--production-branch" "${1:-}"
        production_branch="$1"
        ;;
      --repo-url)
        shift
        require_value "--repo-url" "${1:-}"
        repo_url="$1"
        ;;
      --llama-port)
        shift
        require_value "--llama-port" "${1:-}"
        llama_port="$1"
        llama_port_explicit="1"
        ;;
      --llama-model)
        shift
        require_value "--llama-model" "${1:-}"
        llama_model="$1"
        ;;
      --enable-federation)
        enable_federation="1"
        ;;
      --slave-mode)
        swarm_role="slave"
        enable_federation="1"
        ;;
      --connect-to)
        shift
        require_value "--connect-to" "${1:-}"
        federation_connect_to="$1"
        swarm_role="slave"
        enable_federation="1"
        ;;
      --enable-federation-adb)
        federation_adb_enabled="1"
        enable_federation="1"
        ;;
      --enable-slack-bot)
        enable_slack_bot="1"
        slack_bot_explicit="1"
        ;;
      --federation-peer)
        shift
        require_value "--federation-peer" "${1:-}"
        if [[ -n "$federation_peers" ]]; then
          federation_peers="${federation_peers},$1"
        else
          federation_peers="$1"
        fi
        ;;
      --federation-remote-workers-file)
        shift
        require_value "--federation-remote-workers-file" "${1:-}"
        federation_remote_workers_file="$1"
        ;;
      --federation-bus-port)
        shift
        require_value "--federation-bus-port" "${1:-}"
        federation_bus_port="$1"
        ;;
      --federation-admin-port)
        shift
        require_value "--federation-admin-port" "${1:-}"
        federation_admin_port="$1"
        ;;
      --federation-node-id)
        shift
        require_value "--federation-node-id" "${1:-}"
        federation_node_id="$1"
        ;;
      --adb-port)
        shift
        require_value "--adb-port" "${1:-}"
        federation_adb_port="$1"
        ;;
      --adb-bin)
        shift
        require_value "--adb-bin" "${1:-}"
        federation_adb_bin="$1"
        ;;
      --env)
        shift
        require_value "--env" "${1:-}"
        env_pairs+=("$1")
        ;;
      --config)
        shift
        require_value "--config" "${1:-}"
        config_pairs+=("$1")
        ;;
      --debug)
        debug_enabled="1"
        debug_explicit="1"
        ;;
      --no-debug)
        debug_enabled="0"
        debug_explicit="1"
        ;;
      --foreground)
        foreground="1"
        ;;
      --dry-run)
        dry_run="1"
        ;;
      --help|-h)
        print_swarm_help
        return 0
        ;;
      *)
        err "Unknown swarm option: $1"
        print_swarm_help
        return 1
        ;;
    esac
    shift
  done

  if [[ -n "$project_lookup" ]]; then
    local project_json
    if ! project_json="$(run_shared_projects_cli status --project "$project_lookup" 2>/dev/null)"; then
      err "Unknown registered project: $project_lookup"
      return 1
    fi
    project_root="$(printf '%s' "$project_json" | json_field rootPath)"
    if [[ -z "$project_name" ]]; then
      project_name="$(printf '%s' "$project_json" | json_field name)"
    fi
    if [[ -z "$project_id" ]]; then
      project_id="$(printf '%s' "$project_json" | json_field projectId)"
    fi
    if [[ -z "$db_path" ]]; then
      db_path="$(printf '%s' "$project_json" | json_field dbPath)"
    fi
  fi

  if [[ -z "$project_lookup" ]] && [[ "$project_root" == "$(pwd)" ]] && ! project_is_setup "$project_root"; then
    local current_project_json
    if current_project_json="$(run_shared_projects_cli status 2>/dev/null)" && [[ "$current_project_json" != "null" ]]; then
      project_root="$(printf '%s' "$current_project_json" | json_field rootPath)"
      if [[ -z "$project_name" ]]; then
        project_name="$(printf '%s' "$current_project_json" | json_field name)"
      fi
      if [[ -z "$project_id" ]]; then
        project_id="$(printf '%s' "$current_project_json" | json_field projectId)"
      fi
      if [[ -z "$db_path" ]]; then
        db_path="$(printf '%s' "$current_project_json" | json_field dbPath)"
      fi
    fi
  fi

  mkdir -p "$project_root"
  project_root="$(cd "$project_root" && pwd)"

  if ! project_is_setup "$project_root"; then
    err "Project is not set up: $project_root"
    err "Run: DroidSwarm setup --project-root \"$project_root\" --project-mode <greenfield|existing>"
    return 1
  fi

  load_project_setup "$project_root"

  if [[ -z "$project_name" ]]; then
    project_name="${DROIDSWARM_PROJECT_NAME:-}"
  fi

  if [[ -z "$project_id" ]]; then
    project_id="${DROIDSWARM_PROJECT_ID:-}"
  fi

  project_mode="${DROIDSWARM_PROJECT_MODE:-}"
  if [[ "$slack_bot_explicit" != "1" ]]; then
    enable_slack_bot="${DROIDSWARM_ENABLE_SLACK_BOT:-0}"
  fi

  if [[ -z "$main_branch" ]]; then
    main_branch="${DROIDSWARM_MAIN_BRANCH:-main}"
  fi

  if [[ -z "$production_branch" ]]; then
    production_branch="${DROIDSWARM_PRODUCTION_BRANCH:-production}"
  fi

  if [[ "$debug_explicit" != "1" && -z "$debug_enabled" ]]; then
    debug_enabled="${DROIDSWARM_DEBUG:-0}"
  fi

  db_path="${DROIDSWARM_DB_PATH:-}"
  if [[ -z "$db_path" ]]; then
    db_path="$(project_db_file "$project_root")"
  fi

  if [[ -z "$federation_remote_workers_file" ]]; then
    federation_remote_workers_file="${DROIDSWARM_FEDERATION_REMOTE_WORKERS_FILE:-}"
  fi
  if [[ -z "$federation_remote_workers_file" ]]; then
    local candidate_remote_workers_file
    candidate_remote_workers_file="$(project_federation_workers_file "$project_root")"
    if [[ -f "$candidate_remote_workers_file" ]]; then
      federation_remote_workers_file="$candidate_remote_workers_file"
    fi
  fi

  if [[ -z "$swarm_id" ]]; then
    swarm_id="${project_id}-$(date +%s)"
  fi

  if swarm_exists "$swarm_id"; then
    err "Swarm already exists: $swarm_id"
    return 1
  fi

  replace_project_swarms "$project_root" "$project_id" "$swarm_id"

  if [[ -z "$dashboard_port" ]]; then
    dashboard_port="${DROIDSWARM_DASHBOARD_PORT:-}"
  fi

  if [[ -z "$dashboard_port" ]]; then
    dashboard_port="$(next_available_port 3000)"
  elif ! port_is_free "$dashboard_port"; then
    if [[ "$dashboard_port_explicit" == "1" ]]; then
      err "Dashboard port is already in use: $dashboard_port"
      return 1
    fi
    dashboard_port="$(next_available_port 3000)"
  fi

  if [[ -z "$ws_port" ]]; then
    ws_port="${DROIDSWARM_WS_PORT:-}"
  fi

  if [[ -z "$ws_port" ]]; then
    ws_port="$(next_available_port 8765)"
  elif [[ "$ws_port" == "$dashboard_port" ]] || ! port_is_free "$ws_port"; then
    if [[ "$ws_port_explicit" == "1" ]]; then
      if [[ "$ws_port" == "$dashboard_port" ]]; then
        err "WebSocket port must be different from dashboard port: $ws_port"
      else
        err "WebSocket port is already in use: $ws_port"
      fi
      return 1
    fi
    ws_port="$(next_available_port 8765)"
  fi

  while [[ "$ws_port" == "$dashboard_port" ]] || ! port_is_free "$ws_port"; do
    ws_port=$((ws_port + 1))
  done

  local state_dir log_file
  state_dir="$(swarm_dir "$swarm_id")"
  log_file="$(swarm_log_file "$swarm_id")"
  local workspace_root install_runtime_root install_models_root
  local llama_adopt
  local llama_adopt_pid
  local llama_binding
  workspace_root="$(cd "$ROOT_DIR/../.." 2>/dev/null && pwd || true)"
  install_runtime_root="$ROOT_DIR/runtime"
  install_models_root="${DROIDSWARM_MODELS_DIR:-$DROIDSWARM_HOME/models}"
  specs_dir="$ROOT_DIR/specs"
  llama_adopt="0"
  llama_adopt_pid=""

  if [[ -z "$node_bin" || ! -x "$node_bin" ]]; then
    err "Node.js is required to start a swarm."
    return 1
  fi

  socket_server_entry="$(resolve_runtime_value "${DROIDSWARM_SOCKET_SERVER_ENTRY:-}" \
    "$install_runtime_root/socket-server/main.js" \
    "$workspace_root/dist/apps/socket-server/main.js" || true)"
  orchestrator_entry="$(resolve_runtime_value "${DROIDSWARM_ORCHESTRATOR_ENTRY:-}" \
    "$install_runtime_root/orchestrator/main.js" \
    "$workspace_root/dist/apps/orchestrator/main.js" || true)"
  dashboard_server_entry="$(resolve_runtime_value "${DROIDSWARM_DASHBOARD_SERVER_ENTRY:-}" \
    "$install_runtime_root/dashboard/server.js" \
    "$install_runtime_root/dashboard/apps/dashboard/server.js" \
    "$workspace_root/dist/apps/dashboard/.next/standalone/server.js" \
    "$workspace_root/dist/apps/dashboard/.next/standalone/apps/dashboard/server.js" || true)"
  dashboard_static_dir="$(resolve_runtime_dir_value "${DROIDSWARM_DASHBOARD_STATIC_DIR:-}" \
    "$install_runtime_root/dashboard/dist/apps/dashboard/.next/static" \
    "$install_runtime_root/dashboard/.next/static" \
    "$install_runtime_root/dashboard/apps/dashboard/.next/static" \
    "$workspace_root/dist/apps/dashboard/.next/static" || true)"
  dashboard_public_dir="$(resolve_runtime_dir_value "${DROIDSWARM_DASHBOARD_PUBLIC_DIR:-}" \
    "$install_runtime_root/dashboard/public" \
    "$install_runtime_root/dashboard/apps/dashboard/public" \
    "$workspace_root/apps/dashboard/public" || true)"
  worker_host_entry="$(resolve_runtime_value "${DROIDSWARM_WORKER_HOST_ENTRY:-}" \
    "${DROIDSWARM_DEFAULT_WORKER_HOST_ENTRY:-$install_runtime_root/worker-host/main.js}" \
    "$install_runtime_root/worker-host/main.js" \
    "$install_runtime_root/worker-host/main.cjs" \
    "$workspace_root/dist/apps/worker-host/main.js" \
    "$workspace_root/dist/apps/worker-host/main.cjs" || true)"
  slack_bot_entry="$(resolve_runtime_value "${DROIDSWARM_SLACK_BOT_ENTRY:-}" \
    "$install_runtime_root/slack-bot/main.js" \
    "$workspace_root/dist/apps/slack-bot/main.js" || true)"
  federation_bus_entry="$(resolve_runtime_value "${DROIDSWARM_FEDERATION_BUS_ENTRY:-}" \
    "$install_runtime_root/federation-bus/service.js" \
    "$install_runtime_root/federation-bus/src/service.js" \
    "$workspace_root/dist/packages/federation-bus/src/service.js" \
    "$workspace_root/dist/packages/federation-bus/src/index.js" || true)"
  federation_adb_entry="$(resolve_runtime_value "${DROIDSWARM_FEDERATION_ADB_ENTRY:-}" \
    "$install_runtime_root/federation-adb/service.js" \
    "$install_runtime_root/federation-adb/src/service.js" \
    "$workspace_root/dist/packages/federation-adb/src/service.js" || true)"

  if [[ "$enable_federation" == "1" ]]; then
    if [[ -z "$federation_bus_entry" ]]; then
      err "Missing federation-bus build artifact."
      err "Expected dist/packages/federation-bus/src/service.js or an installed runtime copy."
      err "Run: nx build federation-bus"
      return 1
    fi

    if [[ -z "$federation_node_id" ]]; then
      federation_node_id="$swarm_id"
    fi

    if [[ -z "$federation_bus_port" && -z "$federation_admin_port" ]]; then
      federation_bus_port="$(next_available_port 4947)"
      federation_admin_port="$((federation_bus_port + 3))"
    elif [[ -z "$federation_bus_port" && -n "$federation_admin_port" ]]; then
      federation_bus_port="$((federation_admin_port - 3))"
    elif [[ -n "$federation_bus_port" && -z "$federation_admin_port" ]]; then
      federation_admin_port="$((federation_bus_port + 3))"
    fi

    if [[ -n "$federation_bus_port" && -n "$federation_admin_port" ]]; then
      if ! port_is_free "$federation_bus_port" || ! port_is_free "$federation_admin_port"; then
        err "Federation ports are already in use: bus=$federation_bus_port admin=$federation_admin_port"
        return 1
      fi
      federation_bus_url="http://${federation_host}:${federation_bus_port}"
      federation_admin_url="http://${federation_host}:${federation_admin_port}"
    fi

    if [[ "$swarm_role" == "slave" && -n "$federation_connect_to" && -z "$federation_peers" ]]; then
      federation_peers="$federation_connect_to"
    fi

    if [[ "$federation_adb_enabled" == "1" ]]; then
      if [[ -z "$federation_adb_entry" ]]; then
        err "Missing federation-adb build artifact."
        err "Expected dist/packages/federation-adb/src/service.js or an installed runtime copy."
        err "Run: nx build federation-adb"
        return 1
      fi
      if [[ -z "$federation_adb_port" ]]; then
        federation_adb_port="$(next_available_port 4961)"
      fi
    fi
  fi

  if [[ -z "$socket_server_entry" ]]; then
    err "Missing socket-server build artifact."
    err "Expected dist/apps/socket-server/main.js or installed runtime copy."
    err "Run: nx build socket-server"
    return 1
  fi

  if [[ -z "$orchestrator_entry" ]]; then
    err "Missing orchestrator build artifact."
    err "Expected dist/apps/orchestrator/main.js or installed runtime copy."
    err "Run: nx build orchestrator"
    return 1
  fi

  if [[ -z "$dashboard_server_entry" ]]; then
    err "Missing dashboard standalone server artifact."
    err "Expected dist/apps/dashboard/.next/standalone/.../server.js or installed runtime copy."
    err "Run: nx build dashboard"
    return 1
  fi

  if [[ "$enable_slack_bot" == "1" && -z "$slack_bot_entry" ]]; then
    err "Missing slack-bot build artifact."
    err "Expected dist/apps/slack-bot/main.js or installed runtime copy."
    err "Run: nx build slack-bot"
    return 1
  fi

  dashboard_workdir="$(cd "$(dirname "$dashboard_server_entry")" && pwd)"

  if [[ -z "$operator_token" ]]; then
    operator_token="$(uuid)"
  fi

  if ! ensure_service_runtime_ready; then
    return 1
  fi

  if [[ -f "$DROIDSWARM_SERVICE_CONFIG" ]]; then
    # shellcheck disable=SC1090
    source "$DROIDSWARM_SERVICE_CONFIG"
  fi

  if [[ -z "$llama_port" ]]; then
    llama_port="${DROIDSWARM_LLAMA_PORT:-11434}"
  fi
  llama_binding="$(resolve_service_binding "llama.cpp" "$llama_port" "$llama_port_explicit" 11434 "${DROIDSWARM_LLAMA_SERVER_BIN:-}" "llama-server" "llama.cpp" "llama")" || return 1
  IFS='|' read -r llama_binding_action llama_port llama_adopt_pid <<<"$llama_binding"
  [[ "$llama_binding_action" == "adopt" ]] && llama_adopt="1"

  if [[ -z "$llama_model" ]]; then
    llama_model="${DROIDSWARM_LLAMA_MODEL:-${DROIDSWARM_DEFAULT_LLAMA_MODEL:-$install_models_root/default.gguf}}"
  fi

  info "Swarm ID: $swarm_id"
  info "Project: $project_name ($project_id)"
  info "Project root: $project_root"
  info "Swarm role: $swarm_role"
  info "Dashboard port: $dashboard_port"
  info "WebSocket port: $ws_port"
  info "llama.cpp port: $llama_port"
  info "Federation: $( [[ "$enable_federation" == "1" ]] && printf 'enabled' || printf 'disabled' )"
  info "Slack bot: $( [[ "$enable_slack_bot" == "1" ]] && printf 'enabled' || printf 'disabled' )"
  if [[ "$enable_federation" == "1" ]]; then
    info "Federation bus port: ${federation_bus_port:-unknown}"
    info "Federation admin port: ${federation_admin_port:-unknown}"
    if [[ "$federation_adb_enabled" == "1" ]]; then
      info "Federation ADB port: ${federation_adb_port:-unknown}"
    fi
  fi
  info "Debug logging: $( [[ "$debug_enabled" == "1" ]] && printf 'on' || printf 'off' )"

  if [[ "$dry_run" == "1" ]]; then
    return 0
  fi

  mkdir -p "$state_dir"
  printf 'starting\n' >"$(swarm_status_file "$swarm_id")"

  cat >"$(swarm_env_file "$swarm_id")" <<EOF
DROIDSWARM_SWARM_ID=$(printf '%q' "$swarm_id")
DROIDSWARM_PROJECT_ROOT=$(printf '%q' "$project_root")
DROIDSWARM_PROJECT_NAME=$(printf '%q' "$project_name")
DROIDSWARM_PROJECT_ID=$(printf '%q' "$project_id")
DROIDSWARM_PROJECT_MODE=$(printf '%q' "$project_mode")
DROIDSWARM_DASHBOARD_PORT=$(printf '%q' "$dashboard_port")
DROIDSWARM_WS_PORT=$(printf '%q' "$ws_port")
DROIDSWARM_DB_PATH=$(printf '%q' "$db_path")
DROIDSWARM_DEBUG=$(printf '%q' "$debug_enabled")
DROIDSWARM_AGENT_COUNT=$(printf '%q' "$agent_count")
DROIDSWARM_MAIN_BRANCH=$(printf '%q' "$main_branch")
DROIDSWARM_PRODUCTION_BRANCH=$(printf '%q' "$production_branch")
DROIDSWARM_REPO_URL=$(printf '%q' "$repo_url")
DROIDSWARM_CREATED_AT=$(printf '%q' "$(now_utc)")
DROIDSWARM_CREATED_EPOCH=$(printf '%q' "$(date +%s)")
DROIDSWARM_NODE_BIN=$(printf '%q' "$node_bin")
DROIDSWARM_OPERATOR_TOKEN=$(printf '%q' "$operator_token")
DROIDSWARM_SOCKET_SERVER_ENTRY=$(printf '%q' "$socket_server_entry")
DROIDSWARM_ORCHESTRATOR_ENTRY=$(printf '%q' "$orchestrator_entry")
DROIDSWARM_DASHBOARD_SERVER_ENTRY=$(printf '%q' "$dashboard_server_entry")
DROIDSWARM_DASHBOARD_STATIC_DIR=$(printf '%q' "$dashboard_static_dir")
DROIDSWARM_DASHBOARD_PUBLIC_DIR=$(printf '%q' "$dashboard_public_dir")
DROIDSWARM_DASHBOARD_WORKDIR=$(printf '%q' "$dashboard_workdir")
DROIDSWARM_WORKER_HOST_ENTRY=$(printf '%q' "$worker_host_entry")
DROIDSWARM_SLACK_BOT_ENTRY=$(printf '%q' "$slack_bot_entry")
DROIDSWARM_VERSION=$(printf '%q' "$DROIDSWARM_VERSION")
DROIDSWARM_SPECS_DIR=$(printf '%q' "$specs_dir")
DROIDSWARM_LLAMA_PORT=$(printf '%q' "$llama_port")
DROIDSWARM_ADOPT_LLAMA=$(printf '%q' "$llama_adopt")
DROIDSWARM_ADOPT_LLAMA_PID=$(printf '%q' "$llama_adopt_pid")
DROIDSWARM_LLAMA_MODEL=$(printf '%q' "$llama_model")
DROIDSWARM_SERVICE_CONFIG=$(printf '%q' "$DROIDSWARM_SERVICE_CONFIG")
DROIDSWARM_ENABLE_SLACK_BOT=$(printf '%q' "$enable_slack_bot")
DROIDSWARM_SLACK_KEYCHAIN_SERVICE=$(printf '%q' "${DROIDSWARM_SLACK_KEYCHAIN_SERVICE:-DroidSwarm Slack}")
DROIDSWARM_ENABLE_FEDERATION=$(printf '%q' "$enable_federation")
DROIDSWARM_SWARM_ROLE=$(printf '%q' "$swarm_role")
DROIDSWARM_FEDERATION_CONNECT_TO=$(printf '%q' "$federation_connect_to")
DROIDSWARM_FEDERATION_NODE_ID=$(printf '%q' "$federation_node_id")
DROIDSWARM_FEDERATION_HOST=$(printf '%q' "$federation_host")
DROIDSWARM_FEDERATION_BUS_PORT=$(printf '%q' "$federation_bus_port")
DROIDSWARM_FEDERATION_ADMIN_PORT=$(printf '%q' "$federation_admin_port")
DROIDSWARM_FEDERATION_BUS_URL=$(printf '%q' "$federation_bus_url")
DROIDSWARM_FEDERATION_ADMIN_URL=$(printf '%q' "$federation_admin_url")
DROIDSWARM_FEDERATION_PEERS=$(printf '%q' "$federation_peers")
DROIDSWARM_FEDERATION_REMOTE_WORKERS_FILE=$(printf '%q' "$federation_remote_workers_file")
DROIDSWARM_FEDERATION_BUS_ENTRY=$(printf '%q' "$federation_bus_entry")
DROIDSWARM_ENABLE_FEDERATION_ADB=$(printf '%q' "$federation_adb_enabled")
DROIDSWARM_FEDERATION_ADB_PORT=$(printf '%q' "$federation_adb_port")
DROIDSWARM_FEDERATION_ADB_BIN=$(printf '%q' "$federation_adb_bin")
DROIDSWARM_FEDERATION_ADB_ENTRY=$(printf '%q' "$federation_adb_entry")
DROIDSWARM_ADOPT_FEDERATION=$(printf '%q' "$federation_adopt")
DROIDSWARM_ADOPT_FEDERATION_PID=$(printf '%q' "$federation_adopt_pid")
EOF

  write_env_assignment_file "$state_dir/env.list" "${env_pairs[@]-}"
  write_env_assignment_file "$state_dir/config.list" "${config_pairs[@]-}"
  write_project_metadata \
    "$project_root" \
    "$project_name" \
    "$project_id" \
    "$project_mode" \
    "$main_branch" \
    "$production_branch" \
    "$dashboard_port" \
    "$ws_port" \
    "$db_path"
  write_project_setup_state \
    "$project_root" \
    "$project_name" \
    "$project_id" \
    "$project_mode" \
    "$main_branch" \
    "$production_branch" \
    "$dashboard_port" \
    "$ws_port" \
    "$db_path" \
    "$DROIDSWARM_VERSION" \
    "$specs_dir" \
    "$enable_federation" \
    "$federation_adb_enabled" \
    "$federation_peers" \
    "$federation_remote_workers_file" \
    "$enable_slack_bot"

  if [[ "$foreground" == "1" ]]; then
    "$ROOT_DIR/libexec/droidswarm-daemon.sh" "$swarm_id" "$state_dir"
  else
    nohup "$ROOT_DIR/libexec/droidswarm-daemon.sh" "$swarm_id" "$state_dir" >>"$log_file" 2>&1 &
    local pid="$!"
    printf '%s\n' "$pid" >"$(swarm_pid_file "$swarm_id")"
    info "Started DroidSwarm '$swarm_id' (pid $pid)"
    sleep 2
    print_swarm_runtime_status "$swarm_id"
  fi
}

print_swarm_runtime_status() {
  local swarm_id="$1"
  local include_header="${2:-1}"

  if ! load_swarm_env "$swarm_id"; then
    err "Unable to load swarm state for $swarm_id"
    return 1
  fi

  local pid status uptime
  local socket_component_status dashboard_component_status orch_component_status
  local slack_component_status
  local llama_component_status federation_component_status federation_adb_component_status
  local dashboard_url ws_url federation_bus_url federation_admin_url
  local health_file federation_file llama_health inventory_health exports_health health_updated_at
  local federation_state federation_peer_count federation_recent_event_count

  pid="-"
  status="stopped"
  uptime="-"
  socket_component_status="-"
  dashboard_component_status="-"
  orch_component_status="-"
  slack_component_status="-"
  llama_component_status="-"
  federation_component_status="-"
  federation_adb_component_status="-"
  dashboard_url="-"
  ws_url="-"
  federation_bus_url="-"
  federation_admin_url="-"
  llama_health="unknown"
  inventory_health="unknown"
  exports_health="unknown"
  health_updated_at=""
  federation_state="disabled"
  federation_peer_count="-"
  federation_recent_event_count="-"

  if [[ -f "$(swarm_status_file "$swarm_id")" ]]; then
    status="$(<"$(swarm_status_file "$swarm_id")")"
  fi
  if [[ -f "$(swarm_pid_file "$swarm_id")" ]]; then
    pid="$(<"$(swarm_pid_file "$swarm_id")")"
    if is_pid_running "$pid"; then
      [[ "$status" == "stopped" ]] && status="running"
      uptime="$(format_duration "${DROIDSWARM_CREATED_EPOCH:-0}")"
    else
      [[ "$status" == "running" ]] && status="degraded"
    fi
  fi
  if [[ -f "$(component_status_file "socket-server" "$(swarm_dir "$swarm_id")")" ]]; then
    socket_component_status="$(<"$(component_status_file "socket-server" "$(swarm_dir "$swarm_id")")")"
  fi
  if [[ -f "$(component_status_file "dashboard" "$(swarm_dir "$swarm_id")")" ]]; then
    dashboard_component_status="$(<"$(component_status_file "dashboard" "$(swarm_dir "$swarm_id")")")"
  fi
  if [[ -f "$(component_status_file "orchestrator" "$(swarm_dir "$swarm_id")")" ]]; then
    orch_component_status="$(<"$(component_status_file "orchestrator" "$(swarm_dir "$swarm_id")")")"
  fi
  if [[ -f "$(component_status_file "slack-bot" "$(swarm_dir "$swarm_id")")" ]]; then
    slack_component_status="$(<"$(component_status_file "slack-bot" "$(swarm_dir "$swarm_id")")")"
  fi
  if [[ -f "$(service_status_file "llama.cpp" "$(swarm_dir "$swarm_id")")" ]]; then
    llama_component_status="$(<"$(service_status_file "llama.cpp" "$(swarm_dir "$swarm_id")")")"
  fi
  if [[ -f "$(service_status_file "federation-bus" "$(swarm_dir "$swarm_id")")" ]]; then
    federation_component_status="$(<"$(service_status_file "federation-bus" "$(swarm_dir "$swarm_id")")")"
  fi
  if [[ -f "$(service_status_file "federation-adb" "$(swarm_dir "$swarm_id")")" ]]; then
    federation_adb_component_status="$(<"$(service_status_file "federation-adb" "$(swarm_dir "$swarm_id")")")"
  fi

  dashboard_url="$(format_local_http_url "${DROIDSWARM_DASHBOARD_PORT:-"-"}")"
  if [[ -n "${DROIDSWARM_WS_PORT:-}" ]]; then
    ws_url="ws://127.0.0.1:${DROIDSWARM_WS_PORT}"
  fi
  if [[ -n "${DROIDSWARM_FEDERATION_BUS_URL:-}" ]]; then
    federation_bus_url="${DROIDSWARM_FEDERATION_BUS_URL}"
  fi
  if [[ -n "${DROIDSWARM_FEDERATION_ADMIN_URL:-}" ]]; then
    federation_admin_url="${DROIDSWARM_FEDERATION_ADMIN_URL}"
  fi
  health_file="$(swarm_service_health_file "$swarm_id")"
  if [[ -f "$health_file" ]]; then
    # shellcheck disable=SC1090
    source "$health_file"
    [[ "${DROIDSWARM_HEALTH_LLAMA_REACHABLE:-0}" == "1" ]] && llama_health="ok" || llama_health="unreachable"
    if [[ "${DROIDSWARM_HEALTH_LLAMA_MODEL_PRESENT:-0}" == "1" && "${DROIDSWARM_HEALTH_LLAMA_INVENTORY_HAS_SELECTED:-0}" == "1" ]]; then
      inventory_health="ok"
    else
      inventory_health="missing"
    fi
    if [[ -n "${DROIDSWARM_HEALTH_LLAMA_URL:-}" ]]; then
      exports_health="ready"
    else
      exports_health="incomplete"
    fi
    health_updated_at="${DROIDSWARM_HEALTH_UPDATED_AT:-}"
  fi
  federation_file="$(swarm_federation_status_file "$swarm_id")"
  if [[ -f "$federation_file" ]] && command -v python3 >/dev/null 2>&1; then
    read -r federation_state federation_peer_count federation_recent_event_count federation_bus_url federation_admin_url < <(
      python3 - "$federation_file" <<'PY'
import json
import sys

with open(sys.argv[1], 'r', encoding='utf-8') as handle:
    payload = json.load(handle)

print(
    payload.get('state', 'disabled'),
    payload.get('peerCount', 0),
    payload.get('recentEventCount', 0),
    payload.get('busUrl') or '-',
    payload.get('adminUrl') or '-',
)
PY
    )
  fi

  if [[ "$include_header" == "1" ]]; then
    printf '%-28s %-18s %-10s %-8s %-8s %-8s %-8s %-8s %-12s\n' \
      "SWARM_ID" "PROJECT_ID" "STATUS" "PID" "DASH" "WS" "LLAMA" "FED" "UPTIME"
  fi
  printf '%-28s %-18s %-10s %-8s %-8s %-8s %-8s %-8s %-12s\n' \
    "$swarm_id" \
    "${DROIDSWARM_PROJECT_ID:-unknown}" \
    "$status" \
    "$pid" \
    "${DROIDSWARM_DASHBOARD_PORT:-"-"}" \
    "${DROIDSWARM_WS_PORT:-"-"}" \
    "${DROIDSWARM_LLAMA_PORT:-"-"}" \
    "${DROIDSWARM_FEDERATION_BUS_PORT:-"-"}" \
    "$uptime"
  printf '  components: socket=%s dashboard=%s orchestrator=%s slack=%s\n' \
    "$socket_component_status" \
    "$dashboard_component_status" \
    "$orch_component_status" \
    "$slack_component_status"
  printf '  services: llama=%s federation-bus=%s federation-adb=%s\n' \
    "$llama_component_status" \
    "$federation_component_status" \
    "$federation_adb_component_status"
  printf '  urls: dashboard=%s ws=%s federation-bus=%s federation-admin=%s\n' \
    "$dashboard_url" \
    "$ws_url" \
    "$federation_bus_url" \
    "$federation_admin_url"
  printf '  federation: state=%s peers=%s recent-events=%s\n' \
    "$federation_state" \
    "$federation_peer_count" \
    "$federation_recent_event_count"
  printf '  health: llama=%s inventory=%s exports=%s\n' \
    "$llama_health" \
    "$inventory_health" \
    "$exports_health"
  if [[ -n "$health_updated_at" ]]; then
    printf '  health-updated: %s\n' "$health_updated_at"
  fi
}

project_swarm_ids() {
  local project_root="$1"
  local project_id="$2"
  local exclude_swarm_id="${3:-}"
  local swarm_id candidate_root candidate_id

  for swarm_id in $(active_swarm_ids); do
    [[ -n "$exclude_swarm_id" && "$swarm_id" == "$exclude_swarm_id" ]] && continue
    if ! load_swarm_env "$swarm_id"; then
      continue
    fi

    candidate_root="${DROIDSWARM_PROJECT_ROOT:-}"
    candidate_id="${DROIDSWARM_PROJECT_ID:-}"

    if [[ -n "$project_root" && -n "$candidate_root" && "$candidate_root" == "$project_root" ]]; then
      printf '%s\n' "$swarm_id"
      continue
    fi

    if [[ -n "$project_id" && -n "$candidate_id" && "$candidate_id" == "$project_id" ]]; then
      printf '%s\n' "$swarm_id"
    fi
  done
}

replace_project_swarms() {
  local project_root="$1"
  local project_id="$2"
  local incoming_swarm_id="$3"
  local existing_ids=()
  local existing_id

  for existing_id in $(project_swarm_ids "$project_root" "$project_id" "$incoming_swarm_id"); do
    existing_ids+=("$existing_id")
  done

  if [[ "${#existing_ids[@]}" -eq 0 ]]; then
    return 0
  fi

  info "Replacing existing DroidSwarm instances for project '$project_id'"
  for existing_id in "${existing_ids[@]}"; do
    shutdown_one "$existing_id" || true
    remove_swarm_artifacts "$existing_id"
    info "Removed prior project swarm '$existing_id'"
  done
}

swarm_runtime_status() {
  local swarm_id="$1"
  local pid status

  pid=""
  status="stopped"

  if [[ -f "$(swarm_status_file "$swarm_id")" ]]; then
    status="$(<"$(swarm_status_file "$swarm_id")")"
  fi

  if [[ -f "$(swarm_pid_file "$swarm_id")" ]]; then
    pid="$(<"$(swarm_pid_file "$swarm_id")")"
    if [[ -n "$pid" && "$pid" != "-" ]] && is_pid_running "$pid"; then
      [[ "$status" == "stopped" ]] && status="running"
    else
      [[ "$status" == "running" || "$status" == "starting" ]] && status="degraded"
    fi
  fi

  printf '%s\n' "$status"
}

cmd_list() {
  ensure_runtime_dirs

  local show_all="0"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --all)
        show_all="1"
        ;;
      --help|-h)
        cat <<'EOF'
Usage:
  DroidSwarm list [--all]
EOF
        return 0
        ;;
      *)
        err "Unknown list option: $1"
        return 1
        ;;
    esac
    shift
  done

  printf '%-28s %-18s %-10s %-8s %-8s %-8s %-8s %-8s %-12s\n' \
    "SWARM_ID" "PROJECT_ID" "STATUS" "PID" "DASH" "WS" "LLAMA" "FED" "UPTIME"

  local swarm_id pid status uptime
  local found="0"
  for swarm_id in $(active_swarm_ids); do
    if ! load_swarm_env "$swarm_id"; then
      continue
    fi

    pid="-"
    status="stopped"
    uptime="-"

    if [[ -f "$(swarm_status_file "$swarm_id")" ]]; then
      status="$(<"$(swarm_status_file "$swarm_id")")"
    fi

    if [[ -f "$(swarm_pid_file "$swarm_id")" ]]; then
      pid="$(<"$(swarm_pid_file "$swarm_id")")"
      if is_pid_running "$pid"; then
        [[ "$status" == "stopped" ]] && status="running"
        uptime="$(format_duration "${DROIDSWARM_CREATED_EPOCH:-0}")"
      else
        [[ "$status" == "running" ]] && status="degraded"
      fi
    fi

    if [[ "$show_all" != "1" && "$status" != "running" ]]; then
      continue
    fi

    found="1"
    print_swarm_runtime_status "$swarm_id" 0
  done

  if [[ "$found" != "1" ]]; then
    info "No matching DroidSwarm instances found."
  fi
}

cmd_status() {
  ensure_runtime_dirs

  local swarm_id=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --swarm-id)
        shift
        require_value "--swarm-id" "${1:-}"
        swarm_id="$1"
        ;;
      --help|-h)
        print_status_help
        return 0
        ;;
      *)
        err "Unknown status option: $1"
        return 1
        ;;
    esac
    shift
  done

  if ! swarm_id="$(resolve_swarm_id "$swarm_id")"; then
    return 1
  fi

  print_swarm_runtime_status "$swarm_id"
}

cmd_federation_status() {
  ensure_runtime_dirs

  local swarm_id=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --swarm-id)
        shift
        require_value "--swarm-id" "${1:-}"
        swarm_id="$1"
        ;;
      --help|-h)
        print_federation_help
        return 0
        ;;
      *)
        err "Unknown federation status option: $1"
        print_federation_help
        return 1
        ;;
    esac
    shift
  done

  swarm_id="$(resolve_swarm_id "$swarm_id")" || return 1
  load_swarm_env "$swarm_id" || return 1

  local snapshot_file
  snapshot_file="$(swarm_federation_status_file "$swarm_id")"

  info "Swarm: $swarm_id"
  info "Federation: $( [[ "${DROIDSWARM_ENABLE_FEDERATION:-0}" == "1" ]] && printf 'enabled' || printf 'disabled' )"
  info "Bus URL: ${DROIDSWARM_FEDERATION_BUS_URL:-unset}"
  info "Admin URL: ${DROIDSWARM_FEDERATION_ADMIN_URL:-unset}"
  info "ADB supervisor: $( [[ "${DROIDSWARM_ENABLE_FEDERATION_ADB:-0}" == "1" ]] && printf 'enabled' || printf 'disabled' )"

  if [[ -f "$snapshot_file" ]]; then
    cat "$snapshot_file"
  else
    info "No federation snapshot captured yet."
  fi
}

cmd_federation_devices() {
  ensure_runtime_dirs

  local swarm_id=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --swarm-id)
        shift
        require_value "--swarm-id" "${1:-}"
        swarm_id="$1"
        ;;
      --help|-h)
        print_federation_help
        return 0
        ;;
      *)
        err "Unknown federation devices option: $1"
        print_federation_help
        return 1
        ;;
    esac
    shift
  done

  swarm_id="$(resolve_swarm_id "$swarm_id")" || return 1
  load_swarm_env "$swarm_id" || return 1

  if [[ "${DROIDSWARM_ENABLE_FEDERATION_ADB:-0}" == "1" ]] && command -v curl >/dev/null 2>&1; then
    curl -fsS "http://127.0.0.1:${DROIDSWARM_FEDERATION_ADB_PORT}/" && printf '\n'
    return 0
  fi

  if [[ -x "${DROIDSWARM_FEDERATION_ADB_BIN:-}" ]] || command -v "${DROIDSWARM_FEDERATION_ADB_BIN:-adb}" >/dev/null 2>&1; then
    "${DROIDSWARM_FEDERATION_ADB_BIN:-adb}" devices -l
    return 0
  fi

  err "No federation ADB supervisor or adb binary available."
  return 1
}

cmd_federation_onboard() {
  ensure_runtime_dirs

  local swarm_id=""
  local serial=""
  local output_dir=""
  local skip_push="0"
  local remote_dir="/sdcard/Android/data/com.droidswarm/files/federation"
  local register_worker="1"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --swarm-id)
        shift
        require_value "--swarm-id" "${1:-}"
        swarm_id="$1"
        ;;
      --serial)
        shift
        require_value "--serial" "${1:-}"
        serial="$1"
        ;;
      --output-dir)
        shift
        require_value "--output-dir" "${1:-}"
        output_dir="$1"
        ;;
      --remote-dir)
        shift
        require_value "--remote-dir" "${1:-}"
        remote_dir="$1"
        ;;
      --no-register)
        register_worker="0"
        ;;
      --skip-push)
        skip_push="1"
        ;;
      --help|-h)
        print_federation_help
        return 0
        ;;
      *)
        err "Unknown federation onboard option: $1"
        print_federation_help
        return 1
        ;;
    esac
    shift
  done

  if [[ -z "$serial" ]]; then
    err "Missing required option: --serial"
    return 1
  fi

  swarm_id="$(resolve_swarm_id "$swarm_id")" || return 1
  load_swarm_env "$swarm_id" || return 1

  if [[ -z "$output_dir" ]]; then
    output_dir="$(swarm_dir "$swarm_id")/federation-onboarding/$serial"
  fi
  mkdir -p "$output_dir"

  local manifest_path runtime_archive
  manifest_path="$output_dir/manifest.json"
  runtime_archive="$output_dir/runtime.tgz"

  local install_root="${DROIDSWARM_INSTALL_DIR:-$DROIDSWARM_HOME/install}"
  tar -czf "$runtime_archive" -C "$install_root" runtime bin lib libexec specs VERSION >/dev/null 2>&1 || {
    err "Failed to create federation runtime bundle."
    return 1
  }

  cat >"$manifest_path" <<EOF
{
  "version": 1,
  "projectId": "$(json_escape "${DROIDSWARM_PROJECT_ID:-}")",
  "swarmId": "$(json_escape "$swarm_id")",
  "generatedAt": "$(json_escape "$(now_utc)")",
  "nodeId": "$(json_escape "${DROIDSWARM_FEDERATION_NODE_ID:-$swarm_id}")",
  "busUrl": "$(json_escape "${DROIDSWARM_FEDERATION_BUS_URL:-}")",
  "adminUrl": "$(json_escape "${DROIDSWARM_FEDERATION_ADMIN_URL:-}")",
  "runtimeArchivePath": "$(json_escape "$runtime_archive")"
}
EOF

  info "Wrote federation bundle:"
  info "  manifest: $manifest_path"
  info "  runtime:  $runtime_archive"

  if [[ "$register_worker" == "1" ]]; then
    local workers_file
    workers_file="$(project_federation_workers_file "${DROIDSWARM_PROJECT_ROOT:-}")"
    mkdir -p "$(dirname "$workers_file")"
    if command -v python3 >/dev/null 2>&1; then
      python3 - "$workers_file" "$serial" "$remote_dir" "${DROIDSWARM_FEDERATION_NODE_ID:-$swarm_id}" <<'PY'
import json
import os
import sys

workers_file, serial, remote_dir, node_id = sys.argv[1:5]
record = {
    "targetId": f"adb-{serial}",
    "serial": serial,
    "remoteDir": remote_dir,
    "remoteEntry": f"{remote_dir}/runtime/orchestrator/main.js",
    "remoteCommand": "node",
    "nodeId": node_id,
    "engines": ["codex-cli"],
}

try:
    with open(workers_file, "r", encoding="utf-8") as handle:
        payload = json.load(handle)
except Exception:
    payload = []

if not isinstance(payload, list):
    payload = []

payload = [item for item in payload if isinstance(item, dict) and item.get("targetId") != record["targetId"]]
payload.append(record)

with open(workers_file, "w", encoding="utf-8") as handle:
    json.dump(payload, handle, indent=2)
    handle.write("\n")
PY
    else
      cat >"$workers_file" <<EOF
[
  {
    "targetId": "adb-$(json_escape "$serial")",
    "serial": "$(json_escape "$serial")",
    "remoteDir": "$(json_escape "$remote_dir")",
    "remoteEntry": "$(json_escape "$remote_dir")/runtime/orchestrator/main.js",
    "remoteCommand": "node",
    "nodeId": "$(json_escape "${DROIDSWARM_FEDERATION_NODE_ID:-$swarm_id}")",
    "engines": ["codex-cli"]
  }
]
EOF
    fi
    info "Registered federated worker target: $workers_file"
  fi

  if [[ "$skip_push" == "1" ]]; then
    return 0
  fi

  local adb_bin="${DROIDSWARM_FEDERATION_ADB_BIN:-adb}"
  if ! command -v "$adb_bin" >/dev/null 2>&1; then
    err "adb binary not available: $adb_bin"
    return 1
  fi

  "$adb_bin" -s "$serial" shell mkdir -p "$remote_dir"
  "$adb_bin" -s "$serial" push "$manifest_path" "$remote_dir/manifest.json" >/dev/null
  "$adb_bin" -s "$serial" push "$runtime_archive" "$remote_dir/runtime.tgz" >/dev/null
  "$adb_bin" -s "$serial" shell tar -xzf "$remote_dir/runtime.tgz" -C "$remote_dir"
  info "Pushed federation bundle to device: $serial"
}

cmd_federation() {
  ensure_runtime_dirs

  local action="${1:-status}"
  if [[ $# -gt 0 ]]; then
    shift
  fi

  case "$action" in
    status)
      cmd_federation_status "$@"
      ;;
    devices)
      cmd_federation_devices "$@"
      ;;
    onboard)
      cmd_federation_onboard "$@"
      ;;
    help|--help|-h)
      print_federation_help
      ;;
    *)
      err "Unknown federation command: $action"
      print_federation_help
      return 1
      ;;
  esac
}

cmd_nodes() {
  local action="${1:-list}"
  if [[ $# -gt 0 ]]; then
    shift
  fi

  case "$action" in
    list)
      run_shared_projects_cli nodes-list "$@"
      ;;
    kick)
      local node_id="" swarm_id=""
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --node-id)
            shift
            require_value "--node-id" "${1:-}"
            node_id="$1"
            ;;
          --swarm-id)
            shift
            require_value "--swarm-id" "${1:-}"
            swarm_id="$1"
            ;;
          --help|-h)
            print_nodes_help
            return 0
            ;;
          *)
            err "Unknown nodes kick option: $1"
            print_nodes_help
            return 1
            ;;
        esac
        shift
      done

      if [[ -z "$node_id" ]]; then
        err "Missing --node-id"
        return 1
      fi

      run_shared_projects_cli nodes-kick --node-id "$node_id" >/dev/null

      if [[ -n "$swarm_id" || "$(active_swarm_ids | wc -l | tr -d ' ')" != "0" ]]; then
        local resolved_swarm
        resolved_swarm="$(resolve_swarm_id "$swarm_id")" || true
        if [[ -n "$resolved_swarm" ]] && load_swarm_env "$resolved_swarm" && [[ -n "${DROIDSWARM_FEDERATION_ADMIN_URL:-}" ]] && command -v curl >/dev/null 2>&1; then
          curl -fsS \
            -H 'content-type: application/json' \
            -d "{\"payload\":{\"peerId\":\"$(json_escape "$node_id")\"}}" \
            "${DROIDSWARM_FEDERATION_ADMIN_URL%/}/kick" >/dev/null 2>&1 || true
        fi
      fi

      info "Kicked node: $node_id"
      ;;
    help|-h|--help)
      print_nodes_help
      ;;
    *)
      err "Unknown nodes command: $action"
      print_nodes_help
      return 1
      ;;
  esac
}

slack_token_source_status() {
  local service_name="${DROIDSWARM_SLACK_KEYCHAIN_SERVICE:-DroidSwarm Slack}"

  if [[ -n "${DROIDSWARM_SLACK_BOT_TOKEN:-}" && -n "${DROIDSWARM_SLACK_APP_TOKEN:-}" ]]; then
    printf 'env\n'
    return 0
  fi

  if command -v security >/dev/null 2>&1; then
    if security find-generic-password -w -s "$service_name" -a droidswarm-slack-bot-token >/dev/null 2>&1 && \
       security find-generic-password -w -s "$service_name" -a droidswarm-slack-app-token >/dev/null 2>&1; then
      printf 'keychain\n'
      return 0
    fi
  fi

  printf 'missing\n'
}

cmd_slack_status() {
  ensure_runtime_dirs

  local swarm_id=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --swarm-id)
        shift
        require_value "--swarm-id" "${1:-}"
        swarm_id="$1"
        ;;
      --help|-h)
        print_slack_help
        return 0
        ;;
      *)
        err "Unknown slack status option: $1"
        print_slack_help
        return 1
        ;;
    esac
    shift
  done

  swarm_id="$(resolve_swarm_id "$swarm_id")" || return 1
  load_swarm_env "$swarm_id" || return 1

  local component_status token_source
  component_status="-"
  token_source="$(slack_token_source_status)"
  if [[ -f "$(component_status_file "slack-bot" "$(swarm_dir "$swarm_id")")" ]]; then
    component_status="$(<"$(component_status_file "slack-bot" "$(swarm_dir "$swarm_id")")")"
  fi

  info "Swarm: $swarm_id"
  info "Slack bot: $( [[ "${DROIDSWARM_ENABLE_SLACK_BOT:-0}" == "1" ]] && printf 'enabled' || printf 'disabled' )"
  info "Component status: $component_status"
  info "Token source: $token_source"
  info "Keychain service: ${DROIDSWARM_SLACK_KEYCHAIN_SERVICE:-DroidSwarm Slack}"
  info "Entry: ${DROIDSWARM_SLACK_BOT_ENTRY:-unset}"
}

cmd_slack_restart() {
  ensure_runtime_dirs

  local swarm_id=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --swarm-id)
        shift
        require_value "--swarm-id" "${1:-}"
        swarm_id="$1"
        ;;
      --help|-h)
        print_slack_help
        return 0
        ;;
      *)
        err "Unknown slack restart option: $1"
        print_slack_help
        return 1
        ;;
    esac
    shift
  done

  swarm_id="$(resolve_swarm_id "$swarm_id")" || return 1
  load_swarm_env "$swarm_id" || return 1

  if [[ "${DROIDSWARM_ENABLE_SLACK_BOT:-0}" != "1" ]]; then
    err "Slack bot is not enabled for swarm: $swarm_id"
    return 1
  fi

  local pid_file pid
  pid_file="$(component_pid_file "slack-bot" "$(swarm_dir "$swarm_id")")"
  if [[ ! -f "$pid_file" ]]; then
    err "No managed Slack bot process found for swarm: $swarm_id"
    return 1
  fi

  pid="$(<"$pid_file")"
  if [[ -z "$pid" || "$pid" == "-" ]] || ! is_pid_running "$pid"; then
    err "Slack bot process is not currently running for swarm: $swarm_id"
    return 1
  fi

  kill "$pid" 2>/dev/null || true
  info "Requested Slack bot restart for swarm '$swarm_id' (pid $pid)"
}

cmd_slack() {
  local action="${1:-status}"
  if [[ $# -gt 0 ]]; then
    shift
  fi

  case "$action" in
    status)
      cmd_slack_status "$@"
      ;;
    restart)
      cmd_slack_restart "$@"
      ;;
    help|-h|--help)
      print_slack_help
      ;;
    *)
      err "Unknown slack command: $action"
      print_slack_help
      return 1
      ;;
  esac
}

cmd_orchestrator_status() {
  ensure_runtime_dirs

  local swarm_id=""
  local task_id=""
  local limit="10"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --swarm-id)
        shift
        require_value "--swarm-id" "${1:-}"
        swarm_id="$1"
        ;;
      --task-id)
        shift
        require_value "--task-id" "${1:-}"
        task_id="$1"
        ;;
      --limit)
        shift
        require_value "--limit" "${1:-}"
        limit="$1"
        ;;
      --help|-h)
        print_orchestrator_help
        return 0
        ;;
      *)
        err "Unknown orchestrator status option: $1"
        print_orchestrator_help
        return 1
        ;;
    esac
    shift
  done

  if ! swarm_id="$(resolve_swarm_id "$swarm_id")"; then
    return 1
  fi

  if ! command -v sqlite3 >/dev/null 2>&1; then
    err "sqlite3 is required for orchestrator status."
    return 1
  fi

  load_swarm_env "$swarm_id" || return 1

  local db_path="${DROIDSWARM_DB_PATH:-}"
  if [[ -z "$db_path" || ! -f "$db_path" ]]; then
    err "Shared project database not found for swarm: $swarm_id"
    return 1
  fi

  info "Swarm: $swarm_id"
  info "Database: $db_path"
  info "Project: ${DROIDSWARM_PROJECT_NAME:-unknown} (${DROIDSWARM_PROJECT_ID:-unknown})"

  if [[ -n "$task_id" ]]; then
    local escaped_task_id
    escaped_task_id="$(sql_escape "$task_id")"

    sqlite3 "$db_path" ".mode box" "
select task_id,name,status,priority,run_id,updated_at,metadata_json
from tasks
where task_id='${escaped_task_id}';

select attempt_id,agent_name,status,created_at,updated_at,metadata_json
from task_attempts
where task_id='${escaped_task_id}'
order by created_at desc
limit ${limit};

select message_id,message_type,sender_name,substr(coalesce(content,''),1,120) as content_preview,created_at
from messages
where task_id='${escaped_task_id}' or channel_id='${escaped_task_id}'
order by created_at desc
limit ${limit};

select event_id,event_type,detail,normalized_verb,created_at
from execution_events
where task_id='${escaped_task_id}'
order by created_at desc
limit ${limit};
"
    return 0
  fi

  sqlite3 "$db_path" ".mode box" "
select run_id,status,created_at,updated_at
from runs
order by created_at desc
limit ${limit};

select task_id,name,status,priority,updated_at
from tasks
order by updated_at desc
limit ${limit};

select attempt_id,task_id,agent_name,status,updated_at
from task_attempts
order by updated_at desc
limit ${limit};
"
}

cmd_orchestrator_message() {
  ensure_runtime_dirs

  local swarm_id=""
  local task_id=""
  local content=""
  local username="operator_cli"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --swarm-id)
        shift
        require_value "--swarm-id" "${1:-}"
        swarm_id="$1"
        ;;
      --task-id)
        shift
        require_value "--task-id" "${1:-}"
        task_id="$1"
        ;;
      --content)
        shift
        require_value "--content" "${1:-}"
        content="$1"
        ;;
      --username)
        shift
        require_value "--username" "${1:-}"
        username="$1"
        ;;
      --help|-h)
        print_orchestrator_help
        return 0
        ;;
      *)
        err "Unknown orchestrator message option: $1"
        print_orchestrator_help
        return 1
        ;;
    esac
    shift
  done

  if [[ -z "$task_id" || -z "$content" ]]; then
    err "Provide --task-id and --content."
    print_orchestrator_help
    return 1
  fi

  if ! command -v curl >/dev/null 2>&1; then
    err "curl is required for orchestrator message."
    return 1
  fi

  if ! swarm_id="$(resolve_swarm_id "$swarm_id")"; then
    return 1
  fi

  load_swarm_env "$swarm_id" || return 1

  local dashboard_port="${DROIDSWARM_DASHBOARD_PORT:-}"
  if [[ -z "$dashboard_port" ]]; then
    err "Dashboard port not found for swarm: $swarm_id"
    return 1
  fi

  curl -sS -X POST \
    "http://127.0.0.1:${dashboard_port}/api/channels/${task_id}/messages" \
    -H 'Content-Type: application/json' \
    --data "{\"username\":\"$(json_escape "$username")\",\"content\":\"$(json_escape "$content")\"}"
  printf '\n'
}

cmd_orchestrator() {
  ensure_runtime_dirs

  local action="${1:-status}"
  if [[ $# -gt 0 ]]; then
    shift
  fi

  case "$action" in
    status)
      cmd_orchestrator_status "$@"
      ;;
    message|send)
      cmd_orchestrator_message "$@"
      ;;
    --help|-h|help)
      print_orchestrator_help
      ;;
    *)
      err "Unknown orchestrator command: $action"
      print_orchestrator_help
      return 1
      ;;
  esac
}

cmd_update() {
  ensure_runtime_dirs

  local repo_url ref install_root bin_dir
  local force
  repo_url=""
  ref=""
  force="0"
  install_root="${DROIDSWARM_INSTALL_ROOT:-$HOME/.droidswarm/install}"
  bin_dir="${DROIDSWARM_BIN_DIR:-$HOME/.local/bin}"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --repo-url)
        shift
        require_value "--repo-url" "${1:-}"
        repo_url="$1"
        ;;
      --ref)
        shift
        require_value "--ref" "${1:-}"
        ref="$1"
        ;;
      --install-root)
        shift
        require_value "--install-root" "${1:-}"
        install_root="$1"
        ;;
      --bin-dir)
        shift
        require_value "--bin-dir" "${1:-}"
        bin_dir="$1"
        ;;
      --force)
        force="1"
        ;;
      --help|-h)
        print_update_help
        return 0
        ;;
      *)
        err "Unknown update option: $1"
        print_update_help
        return 1
        ;;
    esac
    shift
  done

  local script_path="$ROOT_DIR/scripts/update-droidswarm.sh"
  if [[ ! -x "$script_path" ]]; then
    err "Update script not found: $script_path"
    return 1
  fi

  local -a update_cmd=("/bin/bash" "$script_path")
  [[ -n "$repo_url" ]] && update_cmd+=(--repo-url "$repo_url")
  [[ -n "$ref" ]] && update_cmd+=(--ref "$ref")
  [[ "$force" == "1" ]] && update_cmd+=(--force)

  DROIDSWARM_INSTALL_ROOT="$install_root" \
    DROIDSWARM_BIN_DIR="$bin_dir" \
    DROIDSWARM_DEFAULT_REPO_URL="${repo_url:-https://github.com/Quick-Draw-Development/DroidSwarm}" \
    "${update_cmd[@]}"
}

cmd_repair() {
  ensure_runtime_dirs

  local repo_url ref install_root bin_dir
  local clean_reinstall no_restart
  repo_url=""
  ref=""
  clean_reinstall="0"
  no_restart="0"
  install_root="${DROIDSWARM_INSTALL_ROOT:-$HOME/.droidswarm/install}"
  bin_dir="${DROIDSWARM_BIN_DIR:-$HOME/.local/bin}"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --repo-url)
        shift
        require_value "--repo-url" "${1:-}"
        repo_url="$1"
        ;;
      --ref)
        shift
        require_value "--ref" "${1:-}"
        ref="$1"
        ;;
      --install-root)
        shift
        require_value "--install-root" "${1:-}"
        install_root="$1"
        ;;
      --bin-dir)
        shift
        require_value "--bin-dir" "${1:-}"
        bin_dir="$1"
        ;;
      --clean)
        clean_reinstall="1"
        ;;
      --no-restart)
        no_restart="1"
        ;;
      --help|-h)
        print_repair_help
        return 0
        ;;
      *)
        err "Unknown repair option: $1"
        print_repair_help
        return 1
        ;;
    esac
    shift
  done

  local script_path="$ROOT_DIR/scripts/repair-droidswarm.sh"
  if [[ ! -x "$script_path" ]]; then
    err "Repair script not found: $script_path"
    return 1
  fi

  local -a repair_cmd=("/bin/bash" "$script_path")
  [[ -n "$repo_url" ]] && repair_cmd+=(--repo-url "$repo_url")
  [[ -n "$ref" ]] && repair_cmd+=(--ref "$ref")
  [[ "$clean_reinstall" == "1" ]] && repair_cmd+=(--clean)
  [[ "$no_restart" == "1" ]] && repair_cmd+=(--no-restart)

  DROIDSWARM_INSTALL_ROOT="$install_root" \
    DROIDSWARM_BIN_DIR="$bin_dir" \
    DROIDSWARM_DEFAULT_REPO_URL="${repo_url:-https://github.com/Quick-Draw-Development/DroidSwarm}" \
    "${repair_cmd[@]}"
}

remove_swarm_artifacts() {
  local swarm_id="$1"
  local state_dir
  state_dir="$(swarm_dir "$swarm_id")"

  rm -rf "$state_dir"
  rm -f \
    "$(swarm_log_file "$swarm_id")" \
    "$(component_log_file "$swarm_id" "socket-server")" \
    "$(component_log_file "$swarm_id" "dashboard")" \
    "$(component_log_file "$swarm_id" "orchestrator")" \
    "$(component_log_file "$swarm_id" "worker-host")" \
    "$(component_log_file "$swarm_id" "llama.cpp")"
}

cmd_cleanup() {
  ensure_runtime_dirs

  local swarm_id=""
  local cleanup_all="0"
  local shutdown_running="0"
  local removed_count="0"
  local skipped_count="0"
  local found_count="0"
  local target_ids=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --swarm-id)
        shift
        require_value "--swarm-id" "${1:-}"
        swarm_id="$1"
        ;;
      --all)
        cleanup_all="1"
        ;;
      --shutdown-running)
        shutdown_running="1"
        ;;
      --help|-h)
        print_cleanup_help
        return 0
        ;;
      *)
        err "Unknown cleanup option: $1"
        print_cleanup_help
        return 1
        ;;
    esac
    shift
  done

  if [[ -n "$swarm_id" && "$cleanup_all" == "1" ]]; then
    err "Use either --swarm-id or --all, not both."
    return 1
  fi

  if [[ -n "$swarm_id" ]]; then
    if ! swarm_exists "$swarm_id"; then
      err "Unknown swarm: $swarm_id"
      return 1
    fi
    target_ids=("$swarm_id")
  else
    local id
    for id in $(active_swarm_ids); do
      target_ids+=("$id")
    done
  fi

  if [[ "${#target_ids[@]}" -eq 0 ]]; then
    info "No DroidSwarm instances found."
    return 0
  fi

  local id runtime_status
  for id in "${target_ids[@]}"; do
    found_count=$((found_count + 1))
    runtime_status="$(swarm_runtime_status "$id")"

    if [[ "$runtime_status" == "running" || "$runtime_status" == "starting" ]]; then
      if [[ "$shutdown_running" == "1" ]]; then
        shutdown_one "$id"
        runtime_status="$(swarm_runtime_status "$id")"
      else
        info "Skipping active swarm '$id' (status: $runtime_status). Re-run with --shutdown-running to remove it."
        skipped_count=$((skipped_count + 1))
        continue
      fi
    fi

    if [[ "$cleanup_all" != "1" && -z "$swarm_id" ]]; then
      case "$runtime_status" in
        stopped|failed|degraded)
          ;;
        *)
          info "Skipping swarm '$id' (status: $runtime_status)."
          skipped_count=$((skipped_count + 1))
          continue
          ;;
      esac
    fi

    remove_swarm_artifacts "$id"
    info "Removed DroidSwarm '$id'"
    removed_count=$((removed_count + 1))
  done

  if [[ "$found_count" -gt 0 && "$removed_count" -eq 0 ]]; then
    info "No matching stopped or failed swarms were removed."
  fi

  info "Cleanup complete. removed=$removed_count skipped=$skipped_count"
}

shutdown_one() {
  local swarm_id="$1"
  if ! swarm_exists "$swarm_id"; then
    err "Unknown swarm: $swarm_id"
    return 1
  fi

  local pid=""
  if [[ -f "$(swarm_pid_file "$swarm_id")" ]]; then
    pid="$(<"$(swarm_pid_file "$swarm_id")")"
  fi

  local state_dir
  state_dir="$(swarm_dir "$swarm_id")"

  if [[ -n "$pid" && "$pid" != "-" ]] && is_pid_running "$pid"; then
    kill "$pid"
    local waited=0
    while is_pid_running "$pid" && [[ "$waited" -lt 10 ]]; do
      sleep 1
      waited=$((waited + 1))
    done
    if is_pid_running "$pid"; then
      kill -9 "$pid" 2>/dev/null || true
    fi
  fi

  for component in orchestrator dashboard socket-server slack-bot; do
    local component_pid_path
    component_pid_path="$(component_pid_file "$component" "$state_dir")"
    if [[ ! -f "$component_pid_path" ]]; then
      continue
    fi
    local component_pid
    component_pid="$(<"$component_pid_path")"
    if [[ -n "$component_pid" && "$component_pid" != "-" ]] && is_pid_running "$component_pid"; then
      kill "$component_pid" 2>/dev/null || true
      sleep 1
      if is_pid_running "$component_pid"; then
        kill -9 "$component_pid" 2>/dev/null || true
      fi
    fi
  done

  for service in llama.cpp; do
    local service_pid_path
    service_pid_path="$(service_pid_file "$service" "$state_dir")"
    if [[ ! -f "$service_pid_path" ]]; then
      continue
    fi
    local service_pid
    service_pid="$(<"$service_pid_path")"
    if [[ -n "$service_pid" && "$service_pid" != "-" ]] && is_pid_running "$service_pid"; then
      kill "$service_pid" 2>/dev/null || true
      sleep 1
      if is_pid_running "$service_pid"; then
        kill -9 "$service_pid" 2>/dev/null || true
      fi
    fi
  done

  printf 'stopped\n' >"$(swarm_status_file "$swarm_id")"
  info "Stopped DroidSwarm '$swarm_id'"
}

cmd_shutdown() {
  ensure_runtime_dirs

  local swarm_id=""
  local all="0"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --swarm-id)
        shift
        require_value "--swarm-id" "${1:-}"
        swarm_id="$1"
        ;;
      --all)
        all="1"
        ;;
      --help|-h)
        cat <<'EOF'
Usage:
  DroidSwarm shutdown --swarm-id <id>
  DroidSwarm shutdown --all
EOF
        return 0
        ;;
      *)
        err "Unknown shutdown option: $1"
        return 1
        ;;
    esac
    shift
  done

  if [[ "$all" != "1" && -z "$swarm_id" ]]; then
    err "Provide --swarm-id or --all"
    return 1
  fi

  if [[ "$all" == "1" ]]; then
    local id
    for id in $(active_swarm_ids); do
      shutdown_one "$id" || true
    done
  else
    shutdown_one "$swarm_id"
  fi
}

cmd_project() {
  local subcommand="${1:-status}"
  if [[ $# -gt 0 ]]; then
    shift
  fi

  case "$subcommand" in
    onboard)
      run_shared_projects_cli onboard "$@"
      ;;
    list)
      run_shared_projects_cli list "$@"
      ;;
    status)
      run_shared_projects_cli status "$@"
      ;;
    select)
      run_shared_projects_cli select "$@"
      ;;
    remove)
      run_shared_projects_cli remove "$@"
      ;;
    migrate)
      run_shared_projects_cli migrate "$@"
      ;;
    current)
      run_shared_projects_cli current "$@"
      ;;
    help|-h|--help)
      print_project_help
      ;;
    *)
      err "Unknown project subcommand: $subcommand"
      print_project_help
      return 1
      ;;
  esac
}

case "$COMMAND" in
  setup)
    cmd_setup "$@"
    ;;
  project)
    cmd_project "$@"
    ;;
  swarm)
    cmd_swarm "$@"
    ;;
  federation)
    cmd_federation "$@"
    ;;
  nodes)
    cmd_nodes "$@"
    ;;
  slack)
    cmd_slack "$@"
    ;;
  orchestrator)
    cmd_orchestrator "$@"
    ;;
  update)
    cmd_update "$@"
    ;;
  repair)
    cmd_repair "$@"
    ;;
  list)
    cmd_list "$@"
    ;;
  status)
    cmd_status "$@"
    ;;
  shutdown)
    cmd_shutdown "$@"
    ;;
  cleanup)
    cmd_cleanup "$@"
    ;;
  version)
    print_version
    ;;
  help|-h|--help)
    print_help
    ;;
  *)
    err "Unknown command: $COMMAND"
    print_help
    exit 1
    ;;
esac
