{
  "name": "shared-memory",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "root": "packages/shared-memory",
  "sourceRoot": "packages/shared-memory/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p packages/shared-memory/tsconfig.json"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --noEmit -p packages/shared-memory/tsconfig.json"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --noEmit -p packages/shared-memory/tsconfig.json"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node --import tsx --test packages/shared-memory/src/**/*.spec.ts"
      }
    }
  }
}
