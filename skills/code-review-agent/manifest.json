    },
    {
      "code": "EVT-BUG-FLAG",
      "label": "Bug Flag"
    },
    {
      "code": "EVT-SECURITY-FINDING",
      "label": "Security Finding"
    },
    {
      "code": "EVT-CONSENSUS-REVIEW",
      "label": "Consensus Review"
    }
  ],
  "projectScoped": false,
