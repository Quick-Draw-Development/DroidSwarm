run_shared_projects_cli() {
  node --import tsx "$ROOT_DIR/../shared-projects/src/cli.ts" "$@"
}

json_field() {
  local field_path="${1:?field path required}"
  node -e '
const fs = require("node:fs");
const path = process.argv[1];
const payload = JSON.parse(fs.readFileSync(0, "utf8"));
const value = path.split(".").reduce((cursor, key) => (cursor == null ? undefined : cursor[key]), payload);
if (value == null) {
  process.exit(1);
}
if (typeof value === "object") {
  process.stdout.write(JSON.stringify(value));
} else {
  process.stdout.write(String(value));
}
' "$field_path"
}

