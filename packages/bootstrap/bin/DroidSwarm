#!/usr/bin/env bash

set -euo pipefail

resolve_script_path() {
  local source_path="${BASH_SOURCE[0]}"
  while [[ -L "$source_path" ]]; do
    local source_dir
    source_dir="$(cd -P "$(dirname "$source_path")" && pwd)"
    source_path="$(readlink "$source_path")"
    [[ "$source_path" != /* ]] && source_path="$source_dir/$source_path"
  done
  printf '%s\n' "$(cd -P "$(dirname "$source_path")" && pwd)/$(basename "$source_path")"
}

find_version_file() {
  local candidate
  for candidate in \
    "$ROOT_DIR/VERSION" \
    "$ROOT_DIR/../VERSION" \
    "$ROOT_DIR/../../VERSION" \
    "$ROOT_DIR/../../../VERSION"; do
    if [[ -f "$candidate" ]]; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done

  return 1
}


read_version_value() {
  local version_file
  if version_file="$(find_version_file)" && [[ -f "$version_file" ]]; then
    local version
    IFS= read -r version <"$version_file"
    printf '%s\n' "${version:-0.0.0}"
    return 0
  fi

  printf '0.0.0\n'
  return 1
}


SCRIPT_PATH="$(resolve_script_path)"
SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
ROOT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

# shellcheck source=../lib/droidswarm/common.sh
source "$ROOT_DIR/lib/droidswarm/common.sh"

DROIDSWARM_VERSION="$(read_version_value)"
export DROIDSWARM_VERSION

COMMAND="${1:-help}"
if [[ $# -gt 0 ]]; then
  shift
fi

print_help() {
  cat <<'EOF'
Usage:
  DroidSwarm <command> [options]

Commands:
  setup       Initialize a project for DroidSwarm
  project     Onboard and manage registered projects
  swarm       Start and register a managed DroidSwarm instance
  federation  Inspect federation state and onboard peer devices
  nodes       List or kick federated slave nodes
  slack       Inspect or restart the optional Slack bot service
  orchestrator Inspect orchestrator state and send task-channel messages
  list        List tracked swarms running on this machine
  status      Show detailed status for one managed DroidSwarm instance
  cleanup     Remove stopped/failed swarm records and logs
  repair      Repair the local DroidSwarm install and optionally reinstall cleanly
  shutdown    Shut down one swarm or all swarms
  version     Show the installed DroidSwarm version
  update      Refresh the installed runtime and restart swarms
  help        Show this help

Examples:
  DroidSwarm setup --project-root "$PWD" --project-mode greenfield
  DroidSwarm project onboard --project-root "$PWD"
  DroidSwarm swarm --project-root "$PWD" --env OPENAI_API_KEY=example --config mode=dev
  DroidSwarm federation status
  DroidSwarm orchestrator status
  DroidSwarm orchestrator status --task-id <task-id>
  DroidSwarm orchestrator message --task-id <task-id> --content "Need an update"
  DroidSwarm list
  DroidSwarm status --swarm-id <id>
  DroidSwarm cleanup
  DroidSwarm cleanup --all --shutdown-running
  DroidSwarm repair
  DroidSwarm repair --clean
  DroidSwarm shutdown --swarm-id <id>
  DroidSwarm shutdown --all
EOF
}

